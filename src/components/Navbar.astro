---
import { t, barLinks, type Locale } from '../i18n/utils';
import { posts, postHref } from '../data/posts';
import Img from './Img.astro';

interface Props {
  locale: Locale;
  // Navbar background variant: 'gradient' (default, current behavior),
  // 'light' (transparent over a light hero, purple links/wordmark, solid
  // --warm once scrolled), 'solid' (solid --cream-2 with hairline, for
  // pages with no dark hero below).
  variant?: 'gradient' | 'light' | 'solid';
}

const { locale, variant = 'gradient' } = Astro.props;
const i = t(locale);
const links = barLinks(locale);

// Blog entries for the site search index, generated from the single source
// of truth in data/posts.ts so a new post can never be missing from search.
const searchBlogEntries = {
  es: posts.map(p => ({ title: p.es.title, desc: p.cardBlurb?.es ?? p.es.description, href: postHref('es', p.id) })),
  en: posts.map(p => ({ title: p.en.title, desc: p.cardBlurb?.en ?? p.en.description, href: postHref('en', p.id) })),
};
---

<header id="site-nav" class:list={['navbar', variant !== 'gradient' && `navbar--${variant}`]}>
  <div class="navbar__inner">
    <a href={`/${locale}/`} class="navbar__logo">
      <Img src="/uploads/logo-icon.webp" sizes="64px" loading="eager" alt="Logotipo de Patricio Ruiz, terapeuta: un sol colorido con símbolos alquímicos y astrológicos" class="navbar__logo-icon" />
      <span class="navbar__logo-name">Patricio<br>Ruiz</span>
    </a>
    <nav id="nav-links" class="navbar__links">
      {links.map(link => (
        <a href={link.href} class="navbar__link">{link.label}</a>
      ))}
    </nav>
    <div class="navbar__spacer" aria-hidden="true"></div>
    <!-- Sandwich: parte real de la barra; se transforma en X cuando el menú abre. -->
    <button id="nav-ham" class="nav-ham" aria-label={i.nav.openMenu} aria-controls="menu-overlay" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Search overlay (reutilizado desde el buscador del menú overlay) -->
<div id="search-overlay" class="search-overlay">
  <div class="search-modal">
    <input id="search-input" type="text" placeholder={locale === 'es' ? 'Buscar en el sitio...' : 'Search the site...'} autocomplete="off">
    <button id="search-close" class="search-close" aria-label="Close">&times;</button>
    <div id="search-results" class="search-results"></div>
  </div>
</div>

<script type="application/json" id="search-blog-data" set:html={JSON.stringify(searchBlogEntries)}></script>

<style>
  .navbar {
    position: sticky; top: 0; width: 100%;
    z-index: 220;
    min-height: var(--nav-h);
    background: linear-gradient(100deg, #341A54 0%, #46276E 30%, #7E4E77 56%, #C2B07E 83%, #EAE5D9 100%);
    box-shadow: none;
    transition: box-shadow .35s ease, background .8s cubic-bezier(.22,1,.36,1);
  }
  /* Borde + sombra sutiles tras hacer scroll. */
  .navbar.navbar--scrolled {
    box-shadow: 0 1px 0 rgba(70, 39, 110, .13), 0 4px 20px rgba(40, 20, 60, .16);
  }

  /* ---------- Variant: light ----------
     Para páginas con hero claro (--warm) en vez del degradado oscuro.
     Fondo transparente y wordmark/links en morado (mismo look que
     body.menu-open reusa abajo). Al hacer scroll gana fondo sólido --warm
     para no quedar flotando sobre contenido claro. */
  .navbar.navbar--light {
    background: transparent;
  }
  .navbar.navbar--light .navbar__logo-name { color: var(--purple); }
  .navbar.navbar--light .navbar__link { color: var(--purple); }
  .navbar.navbar--light .navbar__link:hover { color: var(--purple-d); }
  .navbar.navbar--light.navbar--scrolled {
    background: var(--warm);
    box-shadow: 0 1px 0 rgba(70, 39, 110, .13), 0 4px 20px rgba(40, 20, 60, .16);
  }

  /* ---------- Variant: solid ----------
     Para páginas sin hero oscuro debajo (costos, términos, privacidad,
     blogposts). Fondo sólido --cream-2 con hairline inferior vía box-shadow
     (no añade borde real, así no mueve layout). Links/wordmark en morado. */
  .navbar.navbar--solid {
    background: var(--cream-2);
    box-shadow: inset 0 -1px 0 #ece6d8;
  }
  .navbar.navbar--solid .navbar__logo-name { color: var(--purple); }
  .navbar.navbar--solid .navbar__link { color: var(--purple); }
  .navbar.navbar--solid .navbar__link:hover { color: var(--purple-d); }
  .navbar.navbar--solid.navbar--scrolled {
    box-shadow: inset 0 -1px 0 #ece6d8, 0 4px 20px rgba(40, 20, 60, .10);
  }

  .navbar__inner {
    max-width: 1200px; margin: 0 auto; padding: 0 40px;
    min-height: var(--nav-h);
    display: flex; align-items: center; gap: 24px;
  }
  .navbar__logo { display: flex; align-items: center; gap: 12px; text-decoration: none; flex: 1; }
  .navbar__logo-icon { height: 60px; width: auto; display: block; flex: none; }
  .navbar__logo-name {
    font-family: 'Bitter', serif; font-weight: 700; color: #fff;
    font-size: 17px; line-height: 1.12; letter-spacing: .01em;
    transition: color .8s cubic-bezier(.22,1,.36,1);
  }
  /* Con el menú abierto el fondo de la barra desaparece y queda el crema del
     overlay detrás — el logo pasa a morado para seguir siendo legible. */
  :global(body.menu-open) .navbar__logo-name { color: var(--purple); }

  .navbar__links { display: flex; align-items: center; gap: 38px; flex: none; transition: opacity .8s cubic-bezier(.22,1,.36,1); }
  .navbar__link {
    font-family: 'Mulish', sans-serif;
    font-weight: 700; font-size: 12.5px; letter-spacing: .13em; text-transform: uppercase;
    color: #fff; text-decoration: none; white-space: nowrap;
    transition: color .2s;
  }
  .navbar__link:hover { color: var(--sand); }
  /* Con el menú abierto: el fondo de la barra y los links principales
     desaparecen — el logo se queda flotando, en blanco, por encima de todo. */
  :global(body.menu-open) .navbar { background: transparent; box-shadow: none; }
  :global(body.menu-open) .navbar__links { opacity: 0; pointer-events: none; }

  /* Zona derecha vacía: equilibra el logo (flex:1) para centrar el nav. */
  .navbar__spacer { flex: 1; }

  /* ---------- Sandwich (parte de la barra) ---------- */
  .nav-ham {
    flex: none; width: 27px; height: 22px; padding: 0; position: relative;
    background: none; border: none; cursor: pointer; display: block;
  }
  .nav-ham span {
    position: absolute; left: 0; width: 27px; height: 1.5px; display: block;
    background: var(--purple);
    transition: transform .5s cubic-bezier(.22,1,.36,1), opacity .3s ease;
  }
  .nav-ham span:nth-child(1) { top: 0; }
  .nav-ham span:nth-child(2) { top: 10px; }
  .nav-ham span:nth-child(3) { top: 20px; }
  :global(body.menu-open) .nav-ham span:nth-child(1) { transform: translateY(10px) rotate(45deg); }
  :global(body.menu-open) .nav-ham span:nth-child(2) { opacity: 0; transform: scaleX(.4); }
  :global(body.menu-open) .nav-ham span:nth-child(3) { transform: translateY(-10px) rotate(-45deg); }

  @media (max-width: 500px) {
    .navbar__logo-icon { height: 52px; }
    .navbar__logo-name { font-size: 15px; }
  }

  .search-overlay {
    display: none; position: fixed; inset: 0; z-index: 300;
    background: rgba(38, 35, 33, .55); backdrop-filter: blur(4px);
    align-items: flex-start; justify-content: center; padding: 120px 24px 40px;
  }
  .search-overlay.open { display: flex; }
  .search-modal {
    background: #fff; border-radius: 18px; width: 100%; max-width: 560px;
    box-shadow: 0 24px 60px rgba(0,0,0,.2); padding: 0; position: relative; overflow: hidden;
  }
  #search-input {
    width: 100%; border: none; outline: none; padding: 22px 56px 22px 24px;
    font-family: 'Mulish', sans-serif; font-size: 17px; color: var(--ink);
    background: transparent;
  }
  #search-input::placeholder { color: #b0a89d; }
  .search-close {
    position: absolute; top: 14px; right: 18px; background: none; border: none;
    font-size: 26px; color: #999; cursor: pointer; line-height: 1;
  }
  .search-close:hover { color: var(--purple); }
  .search-results {
    max-height: 340px; overflow-y: auto; border-top: 1px solid #f0ece4;
  }
  .search-results:empty { border-top: none; }
</style>

<style is:global>
  .search-result {
    display: block; padding: 16px 24px; text-decoration: none !important; color: inherit !important;
    transition: background .15s; cursor: pointer;
  }
  .search-result:hover { background: var(--cream-2); }
  .search-result__title {
    font-family: 'Bitter', serif; font-weight: 700; color: var(--purple);
    font-size: 16px; margin: 0 0 4px;
  }
  .search-result__desc {
    font-size: 13px; color: #6a6460; margin: 0; line-height: 1.4;
  }
  .search-result__empty {
    padding: 24px; text-align: center; color: #999; font-size: 15px;
  }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  const nav = document.getElementById('site-nav');
  const ham = document.getElementById('nav-ham');
  const overlay = document.getElementById('menu-overlay');   // desktop editorial overlay
  const mobMenu = document.getElementById('mob-menu');        // mobile menu (unchanged)
  const mobClose = document.getElementById('mob-close');
  const DESKTOP = '(min-width: 821px)';

  // --- Sombra al hacer scroll ------------------------------------------------
  // La barra queda siempre fija y visible (degradado permanente); solo se le
  // agrega sombra tras un pequeño scroll para separarla del contenido.
  window.addEventListener('scroll', function() {
    if (!nav) return;
    var y = window.scrollY || document.documentElement.scrollTop;
    nav.classList.toggle('navbar--scrolled', y > 8);
  }, { passive: true });

  // --- Overlay / menú -------------------------------------------------------
  function openDesktop() {
    document.body.classList.add('menu-open');
    if (overlay) overlay.classList.add('open');
    if (ham) ham.setAttribute('aria-expanded', 'true');
  }
  function closeDesktop() {
    document.body.classList.remove('menu-open');
    if (overlay) overlay.classList.remove('open');
    if (ham) ham.setAttribute('aria-expanded', 'false');
  }
  function openMobile() {
    document.body.classList.add('menu-open');
    if (mobMenu) mobMenu.style.display = 'flex';
    if (ham) ham.setAttribute('aria-expanded', 'true');
  }
  function closeMobile() {
    document.body.classList.remove('menu-open');
    if (mobMenu) mobMenu.style.display = 'none';
    if (ham) ham.setAttribute('aria-expanded', 'false');
  }

  function isDesktop() { return window.matchMedia(DESKTOP).matches; }

  if (ham) ham.addEventListener('click', function() {
    var isOpen = document.body.classList.contains('menu-open');
    if (isDesktop()) {
      isOpen ? closeDesktop() : openDesktop();
    } else {
      isOpen ? closeMobile() : openMobile();
    }
  });

  // Cerrar overlay desktop: clic en un link, en el fondo, o Escape.
  if (overlay) {
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay || (e.target.closest && e.target.closest('a'))) closeDesktop();
    });
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && document.body.classList.contains('menu-open')) {
      isDesktop() ? closeDesktop() : closeMobile();
    }
  });

  // Menú móvil (comportamiento existente, sin cambios).
  if (mobClose) mobClose.addEventListener('click', closeMobile);
  if (mobMenu) {
    mobMenu.addEventListener('click', function(e) { if (e.target === mobMenu) closeMobile(); });
    mobMenu.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeMobile); });
  }
});

// Search
(function() {
  var sitePages = {
    es: [
      { title: 'Inicio', desc: 'Terapia de base somática en CDMX y en línea', href: '/es/' },
      { title: 'Sobre mí', desc: 'Patricio Ruiz Abrín, terapeuta de base somática', href: '/es/sobre-mi/' },
      { title: 'Terapia individual', desc: 'Adolescentes y adultos', href: '/es/terapia/individual/' },
      { title: 'Terapia de pareja', desc: 'Atención al vínculo desde la responsabilidad', href: '/es/terapia/pareja/' },
      { title: 'Terapia familiar', desc: 'Acompañamiento para escucharse mejor', href: '/es/terapia/familias/' },
      { title: 'Recursos', desc: 'Artículos antes de tu primera sesión', href: '/es/recursos/' },
      { title: 'Red terapéutica', desc: 'Directorio de terapeutas en México', href: '/es/red-terapeutica/' },
      { title: 'Testimonios', desc: 'Experiencias de personas reales', href: '/es/testimonios/' },
      { title: 'Privacidad', desc: 'Aviso de privacidad', href: '/es/privacidad/' },
    ],
    en: [
      { title: 'Home', desc: 'Somatic-based therapy in Mexico City & Online', href: '/en/' },
      { title: 'About Me', desc: 'Patricio Ruiz Abrín, somatic-based therapist', href: '/en/about-me/' },
      { title: 'Individual Therapy', desc: 'Teens and adults', href: '/en/therapy/individual/' },
      { title: 'Couples Therapy', desc: 'Attention to the bond', href: '/en/therapy/couples/' },
      { title: 'Family Therapy', desc: 'Support for families', href: '/en/therapy/family/' },
      { title: 'Resources', desc: 'Articles before your first session', href: '/en/resources/' },
      { title: 'Therapist Network', desc: 'Directory of therapists in Mexico', href: '/en/therapist-network/' },
      { title: 'Testimonials', desc: 'Real people, real changes', href: '/en/testimonials/' },
      { title: 'Privacy', desc: 'Privacy policy', href: '/en/privacy/' },
    ]
  };

  var blogDataEl = document.getElementById('search-blog-data');
  var blogPages = blogDataEl ? JSON.parse(blogDataEl.textContent) : { es: [], en: [] };
  var pages = {
    es: sitePages.es.concat(blogPages.es),
    en: sitePages.en.concat(blogPages.en),
  };

  var lang = document.documentElement.lang === 'en' ? 'en' : 'es';
  var index = pages[lang] || pages.es;
  var overlay = document.getElementById('search-overlay');
  var input = document.getElementById('search-input');
  var results = document.getElementById('search-results');
  var closeBtn = document.getElementById('search-close');
  var noResults = lang === 'es' ? 'No se encontraron resultados' : 'No results found';

  function open() { overlay.classList.add('open'); input.value = ''; results.innerHTML = ''; input.focus(); }
  function close() { overlay.classList.remove('open'); }

  function search(q) {
    q = q.toLowerCase().trim();
    if (!q) { results.innerHTML = ''; return; }
    var hits = index.filter(function(p) {
      return p.title.toLowerCase().includes(q) || p.desc.toLowerCase().includes(q);
    });
    if (!hits.length) {
      results.innerHTML = '<div class="search-result__empty">' + noResults + '</div>';
      return;
    }
    results.innerHTML = hits.map(function(p) {
      return '<a class="search-result" href="' + p.href + '">' +
        '<div class="search-result__title">' + p.title + '</div>' +
        '<div class="search-result__desc">' + p.desc + '</div></a>';
    }).join('');
  }

  // El buscador del overlay de menú (readonly) abre este modal al enfocarlo.
  // Se enlaza en DOMContentLoaded porque #menu-search-input (MenuOverlay) se
  // parsea después de este script.
  document.addEventListener('DOMContentLoaded', function() {
    var menuSearch = document.getElementById('menu-search-input');
    if (menuSearch) {
      menuSearch.addEventListener('focus', open);
      menuSearch.addEventListener('click', open);
    }
  });
  if (closeBtn) closeBtn.addEventListener('click', close);
  if (overlay) overlay.addEventListener('click', function(e) { if (e.target === overlay) close(); });
  if (input) input.addEventListener('input', function() { search(input.value); });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.classList.contains('open')) close();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); open(); }
  });
})();
</script>
</content>
