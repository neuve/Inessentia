---
import { t, navLinks, type Locale } from '../i18n/utils';
import { posts, postHref } from '../data/posts';
import Img from './Img.astro';

interface Props {
  locale: Locale;
  altHref: string;
}

const { locale, altHref } = Astro.props;
const i = t(locale);
const links = navLinks(locale);

// Blog entries for the site search index, generated from the single source
// of truth in data/posts.ts so a new post can never be missing from search.
const searchBlogEntries = {
  es: posts.map(p => ({ title: p.es.title, desc: p.cardBlurb?.es ?? p.es.description, href: postHref('es', p.id) })),
  en: posts.map(p => ({ title: p.en.title, desc: p.cardBlurb?.en ?? p.en.description, href: postHref('en', p.id) })),
};
---

<header id="site-nav" class="navbar">
  <div class="navbar__inner">
    <a href={`/${locale}/`} class="navbar__logo">
      <Img src="/uploads/logo-icon.webp" sizes="68px" loading="eager" alt="Logotipo de Patricio Ruiz, terapeuta: un sol colorido con símbolos alquímicos y astrológicos" class="navbar__logo-icon" />
      <span class="navbar__logo-name">Patricio<br>Ruiz</span>
    </a>
    <nav id="nav-links" class="navbar__links">
      {links.map(link => (
        <a href={link.href} class="navbar__link">{link.label}</a>
      ))}
    </nav>
    <button id="nav-search-btn" class="navbar__search" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <circle cx="10.5" cy="10.5" r="7"/>
        <line x1="15.5" y1="15.5" x2="21" y2="21"/>
      </svg>
    </button>
    <button id="nav-ham" class="navbar__ham" aria-label={i.nav.openMenu}>
      <svg width="26" height="20" viewBox="0 0 26 20" fill="none">
        <rect y="0" width="26" height="2.5" rx="1.25" fill="#46276E" />
        <rect y="8.75" width="26" height="2.5" rx="1.25" fill="#46276E" />
        <rect y="17.5" width="26" height="2.5" rx="1.25" fill="#46276E" />
      </svg>
    </button>
    <a id="nav-cta-btn" href="https://wa.me/patriciomx" target="_blank" rel="noopener" class="navbar__cta">{i.nav.cta}</a>
  </div>
</header>

<!-- Language toggle -->
<a href={altHref} id="lang-toggle-btn" class="lang-toggle" title={i.langToggleTitle}>{i.langToggle}</a>
<script is:inline define:vars={{ altLocale: locale === 'es' ? 'en' : 'es' }}>
  (function() {
    var btn = document.getElementById('lang-toggle-btn');
    if (btn) btn.addEventListener('click', function() {
      localStorage.setItem('preferred-lang', altLocale);
    });
  })();
</script>

<!-- Search overlay -->
<div id="search-overlay" class="search-overlay">
  <div class="search-modal">
    <input id="search-input" type="text" placeholder={locale === 'es' ? 'Buscar en el sitio...' : 'Search the site...'} autocomplete="off">
    <button id="search-close" class="search-close" aria-label="Close">&times;</button>
    <div id="search-results" class="search-results"></div>
  </div>
</div>

<script type="application/json" id="search-blog-data" set:html={JSON.stringify(searchBlogEntries)}></script>

<style>
  .navbar {
    position: sticky; top: 0; width: 100%;
    z-index: 40; background: var(--cream);
    transition: box-shadow .35s ease, background .35s ease, border-bottom .35s ease, transform .38s cubic-bezier(.22,1,.36,1);
    border-bottom: 1px solid transparent;
  }
  .navbar.navbar--hidden { transform: translateY(-100%); }
  .navbar__inner {
    max-width: 1200px; margin: 0 auto; padding: 10px 32px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;
  }
  .navbar__logo { display: flex; align-items: center; gap: 12px; text-decoration: none; flex: none; }
  .navbar__logo-icon { height: 68px; width: auto; display: block; }
  .navbar__logo-name {
    font-family: 'Zilla Slab', serif; font-weight: 600; color: var(--purple);
    font-size: 18px; line-height: 1.15; letter-spacing: .01em;
  }
  @media (max-width: 500px) {
    .navbar__logo-icon { height: 54px; }
    .navbar__logo-name { font-size: 15px; }
  }
  .navbar__links { display: flex; align-items: center; gap: 28px; flex-wrap: wrap; }
  .navbar__link {
    font-weight: 700; font-size: 13px; letter-spacing: .08em; text-transform: uppercase;
    color: var(--purple); text-decoration: none; white-space: nowrap; transition: color .2s;
  }
  .navbar__link:hover { color: var(--wine); }
  .navbar__ham {
    display: none; align-items: center; justify-content: center;
    background: none; border: none; cursor: pointer; padding: 6px; flex: none;
  }
  .navbar__cta {
    flex: none; white-space: nowrap; background: var(--purple); color: #fff;
    font-weight: 700; font-size: 13px; letter-spacing: .07em; text-transform: uppercase;
    padding: 13px 26px; border-radius: 999px; text-decoration: none;
    transition: transform .25s ease, box-shadow .25s ease, background .25s ease;
  }
  .navbar__cta:hover {
    transform: translateY(-2px); box-shadow: 0 10px 24px rgba(70,39,110,.28); background: var(--purple-d);
  }
  .lang-toggle {
    position: fixed; top: 80px; right: 24px; z-index: 55;
    width: 38px; height: 38px; border-radius: 50%; background: var(--purple);
    color: #fff; display: flex; align-items: center; justify-content: center;
    font-family: 'Mulish', sans-serif; font-weight: 700; font-size: 11px;
    letter-spacing: .05em; text-decoration: none;
    box-shadow: 0 4px 14px rgba(70,39,110,.3); transition: transform .2s, background .2s;
    -webkit-transform: translateZ(0);
  }
  .lang-toggle:hover { transform: scale(1.1); background: var(--purple-d); }

  .navbar__search {
    background: none; border: none; cursor: pointer; padding: 6px; flex: none;
    color: var(--purple); transition: color .2s;
  }
  .navbar__search:hover { color: var(--wine); }

  .search-overlay {
    display: none; position: fixed; inset: 0; z-index: 300;
    background: rgba(38, 35, 33, .55); backdrop-filter: blur(4px);
    align-items: flex-start; justify-content: center; padding: 120px 24px 40px;
  }
  .search-overlay.open { display: flex; }
  .search-modal {
    background: #fff; border-radius: 18px; width: 100%; max-width: 560px;
    box-shadow: 0 24px 60px rgba(0,0,0,.2); padding: 0; position: relative; overflow: hidden;
  }
  #search-input {
    width: 100%; border: none; outline: none; padding: 22px 56px 22px 24px;
    font-family: 'Mulish', sans-serif; font-size: 17px; color: var(--ink);
    background: transparent;
  }
  #search-input::placeholder { color: #b0a89d; }
  .search-close {
    position: absolute; top: 14px; right: 18px; background: none; border: none;
    font-size: 26px; color: #999; cursor: pointer; line-height: 1;
  }
  .search-close:hover { color: var(--purple); }
  .search-results {
    max-height: 340px; overflow-y: auto; border-top: 1px solid #f0ece4;
  }
  .search-results:empty { border-top: none; }
</style>

<style is:global>
  .search-result {
    display: block; padding: 16px 24px; text-decoration: none !important; color: inherit !important;
    transition: background .15s; cursor: pointer;
  }
  .search-result:hover { background: var(--cream-2); }
  .search-result__title {
    font-family: 'Zilla Slab', serif; font-weight: 600; color: var(--purple);
    font-size: 16px; margin: 0 0 4px;
  }
  .search-result__desc {
    font-size: 13px; color: #6a6460; margin: 0; line-height: 1.4;
  }
  .search-result__empty {
    padding: 24px; text-align: center; color: #999; font-size: 15px;
  }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  const nav = document.getElementById('site-nav');
  const ham = document.getElementById('nav-ham');
  const mobMenu = document.getElementById('mob-menu');
  const mobClose = document.getElementById('mob-close');

  var lastScrollY = window.scrollY || document.documentElement.scrollTop;
  window.addEventListener('scroll', function() {
    if (!nav) return;
    var y = window.scrollY || document.documentElement.scrollTop;
    nav.style.boxShadow = y > 8 ? '0 4px 20px rgba(40,20,60,.16)' : 'none';
    nav.style.background = y > 8 ? 'rgba(234,229,217,.97)' : '#EAE5D9';
    nav.style.borderBottom = y > 8 ? '1px solid rgba(70,39,110,.13)' : '1px solid transparent';
    // Hide on scroll-down past 160px, reappear on scroll-up.
    if (y > lastScrollY && y > 160) {
      nav.classList.add('navbar--hidden');
    } else {
      nav.classList.remove('navbar--hidden');
    }
    lastScrollY = y;
  }, { passive: true });

  function openMenu() { if (mobMenu) mobMenu.style.display = 'flex'; }
  function closeMenu() { if (mobMenu) mobMenu.style.display = 'none'; }

  if (ham) ham.addEventListener('click', openMenu);
  if (mobClose) mobClose.addEventListener('click', closeMenu);
  if (mobMenu) {
    mobMenu.addEventListener('click', function(e) { if (e.target === mobMenu) closeMenu(); });
    mobMenu.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeMenu); });
  }
});

// Search
(function() {
  var sitePages = {
    es: [
      { title: 'Inicio', desc: 'Psicoterapia en CDMX y en línea', href: '/es/' },
      { title: 'Sobre mí', desc: 'Patricio Ruiz Abrín, psicoterapeuta', href: '/es/sobre-mi/' },
      { title: 'Terapia individual', desc: 'Adolescentes y adultos', href: '/es/terapia/individual/' },
      { title: 'Terapia de pareja', desc: 'Atención al vínculo desde la responsabilidad', href: '/es/terapia/pareja/' },
      { title: 'Terapia familiar', desc: 'Acompañamiento para escucharse mejor', href: '/es/terapia/familias/' },
      { title: 'Recursos', desc: 'Artículos antes de tu primera sesión', href: '/es/recursos/' },
      { title: 'Red terapéutica', desc: 'Directorio de terapeutas en México', href: '/es/red-terapeutica/' },
      { title: 'Testimonios', desc: 'Experiencias de personas reales', href: '/es/testimonios/' },
      { title: 'Privacidad', desc: 'Aviso de privacidad', href: '/es/privacidad/' },
    ],
    en: [
      { title: 'Home', desc: 'Psychotherapy in Mexico City & Online', href: '/en/' },
      { title: 'About Me', desc: 'Patricio Ruiz Abrín, psychotherapist', href: '/en/about-me/' },
      { title: 'Individual Therapy', desc: 'Teens and adults', href: '/en/therapy/individual/' },
      { title: 'Couples Therapy', desc: 'Attention to the bond', href: '/en/therapy/couples/' },
      { title: 'Family Therapy', desc: 'Support for families', href: '/en/therapy/family/' },
      { title: 'Resources', desc: 'Articles before your first session', href: '/en/resources/' },
      { title: 'Therapist Network', desc: 'Directory of therapists in Mexico', href: '/en/therapist-network/' },
      { title: 'Testimonials', desc: 'Real people, real changes', href: '/en/testimonials/' },
      { title: 'Privacy', desc: 'Privacy policy', href: '/en/privacy/' },
    ]
  };

  var blogDataEl = document.getElementById('search-blog-data');
  var blogPages = blogDataEl ? JSON.parse(blogDataEl.textContent) : { es: [], en: [] };
  var pages = {
    es: sitePages.es.concat(blogPages.es),
    en: sitePages.en.concat(blogPages.en),
  };

  var lang = document.documentElement.lang === 'en' ? 'en' : 'es';
  var index = pages[lang] || pages.es;
  var overlay = document.getElementById('search-overlay');
  var input = document.getElementById('search-input');
  var results = document.getElementById('search-results');
  var btn = document.getElementById('nav-search-btn');
  var closeBtn = document.getElementById('search-close');
  var noResults = lang === 'es' ? 'No se encontraron resultados' : 'No results found';

  function open() { overlay.classList.add('open'); input.value = ''; results.innerHTML = ''; input.focus(); }
  function close() { overlay.classList.remove('open'); }

  function search(q) {
    q = q.toLowerCase().trim();
    if (!q) { results.innerHTML = ''; return; }
    var hits = index.filter(function(p) {
      return p.title.toLowerCase().includes(q) || p.desc.toLowerCase().includes(q);
    });
    if (!hits.length) {
      results.innerHTML = '<div class="search-result__empty">' + noResults + '</div>';
      return;
    }
    results.innerHTML = hits.map(function(p) {
      return '<a class="search-result" href="' + p.href + '">' +
        '<div class="search-result__title">' + p.title + '</div>' +
        '<div class="search-result__desc">' + p.desc + '</div></a>';
    }).join('');
  }

  if (btn) btn.addEventListener('click', open);
  if (closeBtn) closeBtn.addEventListener('click', close);
  if (overlay) overlay.addEventListener('click', function(e) { if (e.target === overlay) close(); });
  if (input) input.addEventListener('input', function() { search(input.value); });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.classList.contains('open')) close();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); open(); }
  });
})();
</script>
