---
// Standard page header (v1.5) — one component, two layouts chosen by
// whether a `photo` is passed:
//   • photo present → split editorial (A): copy left, portrait right.
//   • no photo      → monolith (B): full-bleed statement + floating stat
//                      ribbon card.
// Always carries the brand standard: purple→beige left-to-right gradient
// (never vertical), white text, and (for split) a stat block or (for
// monolith) a floating white stat ribbon overlapping the next section.
// The language toggle is NOT duplicated here — Navbar.astro already
// renders a working floating `.lang-toggle` button sitewide.
//
// Body copy (lead paragraph(s), possibly with inline markup) goes in the
// default slot so pages keep their exact real content — this component
// never invents or paraphrases copy.

export interface Stat {
  value: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  photo?: string;
  photoAlt?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  stats?: Stat[];
  variant?: 'auto' | 'split' | 'monolith';
}

const {
  eyebrow,
  title,
  photo,
  photoAlt = '',
  ctaLabel,
  ctaHref,
  secondaryLabel,
  secondaryHref,
  stats = [],
  variant = 'auto',
} = Astro.props;

const mode = variant === 'auto' ? (photo ? 'split' : 'monolith') : variant;
---

{mode === 'split' ? (
  <section class="site-header site-header--split">
    <div class="site-header__mandala" aria-hidden="true" data-parallax="0.06" data-parallax-max="50"></div>
    <div class="site-header__grid">
      <div data-reveal>
        {eyebrow && <p class="site-header__eyebrow">{eyebrow}</p>}
        <h1 class="site-header__title">{title}</h1>
        <div class="site-header__lead"><slot /></div>
        {(ctaHref || secondaryHref) && (
          <div class="site-header__actions">
            {ctaHref && <a href={ctaHref} target="_blank" rel="noopener" class="btn-white">{ctaLabel}</a>}
            {secondaryHref && <a href={secondaryHref} class="site-header__link">{secondaryLabel}</a>}
          </div>
        )}
        {stats.length > 0 && (
          <div class="site-header__stats">
            {stats.map((s) => (
              <div class="site-header__stat">
                <b>{s.value}</b>
                <span set:html={s.label} />
              </div>
            ))}
          </div>
        )}
      </div>
      <div class="site-header__photo" data-reveal>
        {photo && <img src={photo} alt={photoAlt} width="800" height="1000" fetchpriority="high" loading="eager" data-parallax="0.10" data-parallax-max="32" />}
      </div>
    </div>
  </section>
) : (
  <>
    <section class="site-header site-header--monolith">
      <div class="site-header__mandala site-header__mandala--a" aria-hidden="true" data-parallax="0.06" data-parallax-max="50"></div>
      <div class="site-header__mandala site-header__mandala--b" aria-hidden="true" data-parallax="0.05" data-parallax-max="40"></div>
      <div class="site-header__monolith-inner" data-reveal>
        {eyebrow && <p class="site-header__eyebrow">{eyebrow}</p>}
        <h1 class="site-header__title site-header__title--mono">{title}</h1>
        <div class="site-header__lead site-header__lead--mono"><slot /></div>
        {(ctaHref || secondaryHref) && (
          <div class="site-header__actions">
            {ctaHref && <a href={ctaHref} target="_blank" rel="noopener" class="btn-white">{ctaLabel}</a>}
            {secondaryHref && <a href={secondaryHref} class="site-header__link">{secondaryLabel}</a>}
          </div>
        )}
      </div>
    </section>
    {stats.length > 0 && (
      <div class="site-header__ribbon-wrap">
        <div class="site-header__ribbon">
          {stats.map((s, i) => (
            <>
              {i > 0 && <div class="site-header__ribbon-div" aria-hidden="true"></div>}
              <div class="site-header__ribbon-item">
                <b>{s.value}</b>
                <span set:html={s.label} />
              </div>
            </>
          ))}
        </div>
      </div>
    )}
  </>
)}

<style>
  .site-header {
    position: relative;
    overflow: hidden;
    background: linear-gradient(100deg, #341A54 0%, #46276E 30%, #7E4E77 56%, #C2B07E 83%, #EAE5D9 100%);
  }
  .site-header__mandala {
    position: absolute;
    pointer-events: none;
    background: repeating-conic-gradient(#fff 0deg .55deg, transparent .55deg 7deg);
    -webkit-mask: radial-gradient(circle, transparent 29%, #000 30%, #000 49%, transparent 50%);
    mask: radial-gradient(circle, transparent 29%, #000 30%, #000 49%, transparent 50%);
  }

  /* ---------- Split (A) ---------- */
  .site-header--split { min-height: 88vh; display: flex; align-items: center; }
  .site-header--split .site-header__mandala { top: -140px; right: -120px; width: 560px; height: 560px; opacity: .14; }
  .site-header__grid {
    position: relative; max-width: 1200px; margin: 0 auto; width: 100%;
    padding: 130px 32px 90px;
    display: grid; grid-template-columns: minmax(0,1.12fr) minmax(0,.88fr);
    gap: clamp(36px, 4vw, 72px); align-items: center;
  }
  @media (max-width: 860px) { .site-header__grid { grid-template-columns: 1fr; } }
  .site-header__photo { position: relative; overflow: hidden; border-radius: 18px; box-shadow: 0 30px 70px rgba(35,18,55,.34); aspect-ratio: 4 / 5; }
  .site-header__photo img { position: absolute; top: -10%; left: 0; width: 100%; height: 120%; object-fit: cover; display: block; }

  /* ---------- Monolith (B) ---------- */
  .site-header--monolith { min-height: 66vh; display: flex; align-items: center; padding: 130px 0 96px; }
  .site-header--monolith .site-header__mandala--a { top: 50%; margin-top: -320px; left: 60%; width: 640px; height: 640px; opacity: .13; }
  .site-header--monolith .site-header__mandala--b { --mc: #EAE5D9; background: repeating-conic-gradient(#EAE5D9 0deg .55deg, transparent .55deg 7deg); bottom: -220px; left: -160px; width: 460px; height: 460px; opacity: .16; }
  .site-header__monolith-inner { position: relative; max-width: 780px; margin: 0 auto; padding: 0 32px; text-align: center; }
  .site-header__monolith-inner .site-header__actions { justify-content: center; }
  .site-header__monolith-inner .site-header__lead { max-width: 56ch; margin-left: auto; margin-right: auto; }

  /* ---------- Shared text ---------- */
  .site-header__eyebrow { margin: 0 0 18px; font-weight: 700; font-size: 13px; letter-spacing: .16em; text-transform: uppercase; color: var(--sand); }
  .site-header__title { font-family: 'Zilla Slab', serif; font-weight: 600; color: #fff; font-size: clamp(38px, 5.4vw, 68px); line-height: 1.03; letter-spacing: -.015em; margin: 0 0 22px; text-wrap: balance; }
  .site-header__title--mono { font-size: clamp(40px, 6vw, 76px); line-height: 1.02; }
  .site-header__lead { font-size: clamp(16px, 1.3vw, 19px); line-height: 1.65; color: rgba(255,255,255,.85); max-width: 48ch; margin: 0 0 32px; }
  .site-header__lead :global(p) { margin: 0 0 10px; }
  .site-header__lead :global(p:last-child) { margin-bottom: 0; }
  .site-header__actions { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; margin-bottom: 8px; }
  /* Tertiary CTA: quiet text link so it doesn't compete with the primary white button */
  .site-header__link { color: rgba(255,255,255,.72); font-weight: 600; font-size: 14px; text-decoration: none; border-bottom: 1px solid transparent; padding-bottom: 1px; transition: color .2s, border-color .2s; }
  .site-header__link::after { content: ' \2192'; }
  .site-header__link:hover { color: #fff; border-bottom-color: rgba(255,255,255,.4); }

  /* ---------- Stats (split, inline) ---------- */
  .site-header__stats { display: flex; gap: 34px; flex-wrap: wrap; margin-top: 30px; padding-top: 26px; border-top: 1px solid rgba(255,255,255,.22); }
  .site-header__stat b { font-family: 'Zilla Slab', serif; font-weight: 600; font-size: 46px; line-height: .9; color: #fff; display: block; }
  .site-header__stat span { font-size: 13.5px; line-height: 1.5; color: rgba(255,255,255,.8); display: block; margin-top: 8px; max-width: 20ch; }

  /* ---------- Stat ribbon (monolith, floating card) ---------- */
  .site-header__ribbon-wrap { position: relative; z-index: 6; max-width: 1000px; margin: -48px auto 0; padding: 0 32px; }
  .site-header__ribbon {
    background: #fff; border: 1px solid #ece6d8; border-radius: 20px;
    box-shadow: 0 26px 60px rgba(70,39,110,.16); padding: 28px 36px;
    display: flex; gap: 36px; flex-wrap: wrap; justify-content: space-around; text-align: center;
  }
  .site-header__ribbon-item b { font-family: 'Zilla Slab', serif; font-weight: 600; font-size: 40px; color: var(--wine); display: block; line-height: .9; }
  .site-header__ribbon-item span { font-size: 14px; color: #6a6460; }
  .site-header__ribbon-div { width: 1px; background: #ece6d8; }
</style>
