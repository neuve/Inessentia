---
// Standard page header (v1.5) — one component, two layouts chosen by
// whether a `photo` is passed:
//   • photo present → split editorial (A): copy left, portrait right.
//   • no photo      → monolith (B): full-bleed statement + floating stat
//                      ribbon card.
// Always carries the brand standard: purple→beige left-to-right gradient
// (never vertical), white text, and (for split) a stat block or (for
// monolith) a floating white stat ribbon overlapping the next section.
// The language toggle is NOT duplicated here — Navbar.astro already
// renders a working floating `.lang-toggle` button sitewide.
//
// Body copy (lead paragraph(s), possibly with inline markup) goes in the
// default slot so pages keep their exact real content — this component
// never invents or paraphrases copy.

export interface Stat {
  value: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  /** Small caps meta line under the lead paragraph, e.g. "Presencial CDMX, Col. Nápoles · Online". */
  meta?: string;
  photo?: string;
  photoAlt?: string;
  /** Brand icon shown in a translucent circle above the eyebrow (monolith heros only). */
  icon?: string;
  /** Rendered height of the icon inside the circle, e.g. "132px". */
  iconSize?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  stats?: Stat[];
  variant?: 'auto' | 'split' | 'monolith' | 'panel';
  /** Split only: `object-position` for the portrait inside its 4:5 box, to
   * fine-tune the vertical crop (e.g. `center 30%` on the home hero to drop
   * the wall clock while keeping air above the head). Defaults to the shared
   * framing used across the other pages. */
  photoPosition?: string;
  /** Split only: overrides the portrait box's `aspect-ratio` (default `4 / 5`), e.g. `1 / 1`. */
  photoAspect?: string;
  /** Panel only: larger card (individual page) — 52px title, 960px copy max-width. */
  panelLarge?: boolean;
}

import Img from './Img.astro';

const {
  eyebrow,
  title,
  meta,
  photo,
  photoAlt = '',
  icon,
  iconSize = '120px',
  ctaLabel,
  ctaHref,
  secondaryLabel,
  secondaryHref,
  stats = [],
  variant = 'auto',
  photoPosition,
  photoAspect,
  panelLarge = false,
} = Astro.props;

const mode = variant === 'auto' ? (photo ? 'split' : 'monolith') : variant;
---

{mode === 'split' ? (
  <section class="site-header site-header--split">
    <div class="site-header__mandala" aria-hidden="true" data-parallax="0.06" data-parallax-max="50"></div>
    <div class="site-header__grid">
      <div data-reveal>
        {eyebrow && <p class="site-header__eyebrow">{eyebrow}</p>}
        <h1 class="site-header__title">{title}</h1>
        <div class="site-header__lead"><slot /></div>
        {meta && <h4 class="site-header__meta">{meta}</h4>}
        {(ctaHref || secondaryHref) && (
          <div class="site-header__actions">
            {ctaHref && <a href={ctaHref} target="_blank" rel="noopener" class="btn-white">{ctaLabel}</a>}
            {secondaryHref && <a href={secondaryHref} class="site-header__link">{secondaryLabel}</a>}
          </div>
        )}
        {stats.length > 0 && (
          <div class="site-header__stats">
            {stats.map((s) => (
              <div class="site-header__stat">
                <b>{s.value}</b>
                <span set:html={s.label} />
              </div>
            ))}
          </div>
        )}
      </div>
      <div class="site-header__photo" data-reveal style={`${photoPosition ? `--photo-pos:${photoPosition};` : ''}${photoAspect ? `--photo-aspect:${photoAspect};` : ''}`}>
        {photo && <Img src={photo} alt={photoAlt} sizes="(max-width:900px) 100vw, 50vw" fetchpriority="high" loading="eager" data-parallax="0.10" data-parallax-max="32" />}
      </div>
    </div>
  </section>
) : mode === 'panel' ? (
  <section class="site-header site-header--panel">
    <div class="site-header__panel-rail" aria-hidden="true"></div>
    <div class="site-header__panel-inner" data-reveal>
      <div class={`site-header__panel-copy${panelLarge ? ' site-header__panel-copy--lg' : ''}`}>
        {eyebrow && <p class="site-header__eyebrow site-header__eyebrow--panel">{eyebrow}</p>}
        <h1 class={`site-header__title site-header__title--panel${panelLarge ? ' site-header__title--panel-lg' : ''}`}>{title}</h1>
        <div class={`site-header__lead site-header__lead--panel${panelLarge ? ' site-header__lead--panel-lg' : ''}`}><slot /></div>
        {meta && <h4 class="site-header__meta site-header__meta--panel">{meta}</h4>}
        {(ctaHref || secondaryHref) && (
          <div class="site-header__actions">
            {ctaHref && <a href={ctaHref} target="_blank" rel="noopener" class="btn-primary">{ctaLabel}</a>}
            {secondaryHref && <a href={secondaryHref} class="site-header__link site-header__link--panel">{secondaryLabel}</a>}
          </div>
        )}
      </div>
      {icon && (
        <div class="site-header__panel-icon">
          <Img src={icon} alt="" sizes="160px" style={`height:${iconSize};width:auto;display:block;`} />
        </div>
      )}
    </div>
  </section>
) : (
  <>
    <section class="site-header site-header--monolith">
      <div class="site-header__mandala site-header__mandala--a" aria-hidden="true" data-parallax="0.06" data-parallax-max="50"></div>
      <div class="site-header__mandala site-header__mandala--b" aria-hidden="true" data-parallax="0.05" data-parallax-max="40"></div>
      <div class="site-header__monolith-inner" data-reveal>
        {icon && (
          <div class="site-header__icon">
            <Img src={icon} alt="" sizes="160px" style={`height:${iconSize};width:auto;display:block;`} />
          </div>
        )}
        {eyebrow && <p class="site-header__eyebrow">{eyebrow}</p>}
        <h1 class="site-header__title site-header__title--mono">{title}</h1>
        <div class="site-header__lead site-header__lead--mono"><slot /></div>
        {(ctaHref || secondaryHref) && (
          <div class="site-header__actions">
            {ctaHref && <a href={ctaHref} target="_blank" rel="noopener" class="btn-white">{ctaLabel}</a>}
            {secondaryHref && <a href={secondaryHref} class="site-header__link">{secondaryLabel}</a>}
          </div>
        )}
      </div>
    </section>
    {stats.length > 0 && (
      <div class="site-header__ribbon-wrap">
        <div class="site-header__ribbon">
          {stats.map((s, i) => (
            <>
              {i > 0 && <div class="site-header__ribbon-div" aria-hidden="true"></div>}
              <div class="site-header__ribbon-item">
                <b>{s.value}</b>
                <span set:html={s.label} />
              </div>
            </>
          ))}
        </div>
      </div>
    )}
  </>
)}

<style>
  .site-header {
    position: relative;
    overflow: hidden;
    background: linear-gradient(100deg, #341A54 0%, #46276E 30%, #7E4E77 56%, #C2B07E 83%, #EAE5D9 100%);
  }
  .site-header__mandala {
    position: absolute;
    pointer-events: none;
    background: repeating-conic-gradient(#fff 0deg .55deg, transparent .55deg 7deg);
    -webkit-mask: radial-gradient(circle, transparent 29%, #000 30%, #000 49%, transparent 50%);
    mask: radial-gradient(circle, transparent 29%, #000 30%, #000 49%, transparent 50%);
  }

  /* ---------- Split (A) ---------- */
  .site-header--split { min-height: 88vh; display: flex; align-items: center; }
  .site-header--split .site-header__mandala { top: -140px; right: -120px; width: 560px; height: 560px; opacity: .14; }
  .site-header__grid {
    position: relative; max-width: 1200px; margin: 0 auto; width: 100%;
    padding: 130px 32px 90px;
    display: grid; grid-template-columns: minmax(0,1.12fr) minmax(0,.88fr);
    gap: clamp(36px, 4vw, 72px); align-items: center;
  }
  @media (max-width: 860px) { .site-header__grid { grid-template-columns: 1fr; } }
  /* Portrait: fixed 4:5 box. `--photo-pos` (from the `photoPosition` prop)
     fine-tunes the vertical crop per page; the default replicates the prior
     framing (image at 120% height pulled up 10% ≈ object-position center 8%). */
  .site-header__photo { position: relative; overflow: hidden; border-radius: 18px; box-shadow: 0 30px 70px rgba(35,18,55,.34); aspect-ratio: var(--photo-aspect, 4 / 5); width: 100%; max-width: var(--photo-max-w, none); margin-left: auto; }
  .site-header__photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: var(--photo-pos, center 8%); display: block; }

  /* ---------- Panel (C) ---------- */
  .site-header--panel { background: var(--warm); min-height: 62vh; display: flex; align-items: center; padding: 150px 0 80px; }
  .site-header__panel-rail { position: absolute; inset: 0 auto 0 0; width: 6px; background: linear-gradient(180deg, #8E2B5D 0%, #46276E 55%, #C2B07E 100%); }
  .site-header__panel-inner {
    position: relative; max-width: 1100px; margin: 0 auto; width: 100%; padding: 0 32px 0 48px;
    display: flex; align-items: center; justify-content: space-between; gap: clamp(24px, 4vw, 56px);
  }
  .site-header__panel-copy { max-width: 66%; }
  .site-header__panel-copy--lg { max-width: 960px; }
  .site-header__panel-icon { flex: 0 0 auto; display: flex; align-items: center; justify-content: center; }
  /* Panel text colours must beat the shared white/sand rules below, which
     have equal specificity but come later in source order. Prefix with the
     block class to win regardless of order. */
  .site-header--panel .site-header__eyebrow--panel { color: #8E2B5D; }
  .site-header--panel .site-header__title--panel { color: #46276E; font-size: 34px; line-height: 1.12; }
  .site-header--panel .site-header__title--panel-lg { font-size: clamp(34px, 4.6vw, 52px); line-height: 1.08; }
  .site-header--panel .site-header__lead--panel { color: #3f3a36; font-family: 'Mulish', sans-serif; font-weight: 500; font-size: 14px; max-width: 60ch; }
  .site-header--panel .site-header__lead--panel-lg { font-size: 16px; }
  .site-header__lead--panel :global(p) { margin: 0 0 10px; }
  .site-header__lead--panel :global(p:last-child) { margin-bottom: 0; }
  .site-header--panel .site-header__meta--panel { color: #6a6460; }
  .site-header--panel .site-header__link--panel { color: #8E2B5D; text-decoration: none; border-bottom: none; }
  .site-header--panel .site-header__link--panel:hover { color: #8E2B5D; text-decoration: none; border-bottom: none; }
  @media (max-width: 860px) {
    .site-header__panel-inner { flex-direction: column-reverse; align-items: center; text-align: center; padding-left: 32px; }
    .site-header__panel-copy { max-width: 100%; }
    .site-header__panel-icon { margin: 0 auto; }
    .site-header__panel-copy .site-header__actions { justify-content: center; }
    .site-header__panel-copy .site-header__lead--panel { margin-left: auto; margin-right: auto; }
  }

  /* ---------- Monolith (B) ---------- */
  .site-header--monolith { min-height: 66vh; display: flex; align-items: center; padding: 130px 0 96px; }
  .site-header--monolith .site-header__mandala--a { top: 50%; margin-top: -320px; left: 60%; width: 640px; height: 640px; opacity: .13; }
  .site-header--monolith .site-header__mandala--b { --mc: #EAE5D9; background: repeating-conic-gradient(#EAE5D9 0deg .55deg, transparent .55deg 7deg); bottom: -220px; left: -160px; width: 460px; height: 460px; opacity: .16; }
  .site-header__monolith-inner { position: relative; max-width: 780px; margin: 0 auto; padding: 0 32px; text-align: center; }
  .site-header__monolith-inner .site-header__actions { justify-content: center; }
  .site-header__monolith-inner .site-header__lead { max-width: 56ch; margin-left: auto; margin-right: auto; }
  .site-header__icon {
    width: 172px; height: 172px; border-radius: 50%;
    background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2);
    -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px);
    display: flex; align-items: center; justify-content: center; margin: 0 auto 26px;
  }
  @media (max-width: 520px) { .site-header__icon { width: 140px; height: 140px; } }

  /* ---------- Shared text ---------- */
  .site-header__eyebrow { margin: 0 0 18px; font-weight: 700; font-size: 13px; letter-spacing: .16em; text-transform: uppercase; color: var(--sand); }
  .site-header__title { font-family: 'Bitter', serif; font-weight: 700; color: #fff; font-size: clamp(38px, 5.4vw, 68px); line-height: 1.03; letter-spacing: -.015em; margin: 0 0 22px; text-wrap: balance; }
  .site-header__title--mono { font-size: clamp(40px, 6vw, 76px); line-height: 1.02; }
  .site-header__lead { font-size: clamp(16px, 1.3vw, 19px); line-height: 1.65; color: rgba(255,255,255,.85); max-width: 48ch; margin: 0 0 32px; }
  .site-header__lead :global(p) { margin: 0 0 10px; }
  .site-header__lead :global(p:last-child) { margin-bottom: 0; }
  .site-header__meta { margin: 0 0 30px; font-weight: 600; font-size: 13px; letter-spacing: .08em; text-transform: uppercase; color: rgba(255,255,255,.7); }
  /* Aire balanceado alrededor del pill: ~30px arriba (meta) y ~34px abajo (stats). */
  .site-header__actions { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; margin-bottom: 34px; }
  /* Tertiary CTA: quiet text link so it doesn't compete with the primary white button */
  .site-header__link { color: rgba(255,255,255,.72); font-weight: 600; font-size: 14px; text-decoration: none; border-bottom: 1px solid transparent; padding-bottom: 1px; transition: color .2s, border-color .2s; }
  .site-header__link:hover { color: #fff; border-bottom-color: rgba(255,255,255,.4); }

  /* ---------- Numeralia (split — grid de 3 columnas, sin divisores) ---------- */
  .site-header__stats { display: grid; grid-template-columns: repeat(3, minmax(0, 150px)); gap: clamp(20px, 2.4vw, 34px); }
  .site-header__stat b { font-family: 'Bitter', serif; font-weight: 700; font-size: clamp(34px,4.4vw,42px); line-height: .9; color: #fff; display: block; }
  .site-header__stat span { font-size: 13px; line-height: 1.5; color: rgba(255,255,255,.8); display: block; margin-top: 8px; }
  .site-header__stat span :global(strong) { color: #fff; font-weight: 700; }
  @media (max-width: 420px) {
    .site-header__stats { grid-template-columns: 1fr; gap: 18px; }
  }

  /* ---------- Stat ribbon (monolith, floating card) ---------- */
  .site-header__ribbon-wrap { position: relative; z-index: 6; max-width: 1000px; margin: -48px auto 0; padding: 0 32px; }
  .site-header__ribbon {
    background: #fff; border: 1px solid #ece6d8; border-radius: 20px;
    box-shadow: 0 26px 60px rgba(70,39,110,.16); padding: 28px 36px;
    display: flex; gap: 36px; flex-wrap: wrap; justify-content: space-around; text-align: center;
  }
  .site-header__ribbon-item b { font-family: 'Bitter', serif; font-weight: 700; font-size: 40px; color: var(--wine); display: block; line-height: .9; }
  .site-header__ribbon-item span { font-size: 14px; color: #6a6460; }
  .site-header__ribbon-div { width: 1px; background: #ece6d8; }
</style>

<script is:inline>
  (function () {
    // Contador animado de la numeralia (solo hero split, p. ej. el home).
    var nums = Array.prototype.slice.call(document.querySelectorAll('.site-header__stats b'));
    if (!nums.length) return;
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    nums.forEach(function (el) {
      var target = parseInt((el.textContent || '').replace(/[^0-9]/g, ''), 10);
      if (isNaN(target)) return;
      el.setAttribute('data-final', String(target));
      if (!reduce) el.textContent = '0';
    });
    if (reduce || !('IntersectionObserver' in window)) return;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        io.unobserve(e.target);
        var el = e.target;
        var target = parseInt(el.getAttribute('data-final'), 10);
        var dur = 1400, start = null, done = false;
        function finish() { if (!done) { done = true; el.textContent = String(target); } }
        function step(ts) {
          if (done) return;
          if (start === null) start = ts;
          var p = Math.min((ts - start) / dur, 1);
          var eased = 1 - Math.pow(1 - p, 3);
          el.textContent = String(Math.round(eased * target));
          if (p < 1) requestAnimationFrame(step); else finish();
        }
        requestAnimationFrame(step);
        // Fallback: garantiza el valor final aunque rAF se pause (p. ej. tab en background).
        setTimeout(finish, dur + 300);
      });
    }, { threshold: 0.4 });
    nums.forEach(function (el) { io.observe(el); });
  })();
</script>
