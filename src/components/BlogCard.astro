---
import type { Locale } from '../data/posts';
import { postHref } from '../data/posts';
import type { PostEntry } from '../data/posts';

interface Props {
  post: PostEntry;
  locale: Locale;
  readMoreLabel: string;
}

const { post, locale, readMoreLabel } = Astro.props;
const meta = post[locale];
const blurb = post.cardBlurb ? post.cardBlurb[locale] : meta.description;
const alt = post.cardAlt?.[locale] ?? post.heroAlt[locale];
const heroPosition = post.cardHeroPosition?.[locale] ?? post.heroPosition;
---

<a data-reveal href={postHref(locale, post.id)} class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
  <div style="height:184px;overflow:hidden;"><img src={post.heroImage} width="1200" height="800" loading="lazy" alt={alt} style={`width:100%;height:100%;object-fit:cover;object-position:${heroPosition};display:block;`}></div>
  <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
    <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">{meta.category}</p>
    <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">{meta.title}</h3>
    <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">{blurb}</p>
    <span style="color:var(--wine);font-weight:700;font-size:13px;">{readMoreLabel}</span>
  </div>
</a>
