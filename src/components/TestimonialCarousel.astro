---
import { t, type Locale } from '../i18n/utils';
import { testimonials, homeTeaserIds } from '../data/testimonials';

interface Props { locale: Locale; }

const { locale } = Astro.props;
const i = t(locale);
const testimonialsPath = locale === 'es' ? '/es/testimonios/' : '/en/testimonials/';

const byId = new Map(testimonials[locale].map(item => [item.id, item]));
const items = homeTeaserIds.map(id => byId.get(id)).filter(Boolean);
---

<section class="section">
  <div class="container" style="max-width:1100px;">
    <div style="text-align:center;margin-bottom:clamp(40px,5vw,60px);">
      <p data-reveal class="label-section">{i.testimonials.label}</p>
      <h2 data-reveal class="heading-section">{i.testimonials.title}</h2>
    </div>
    <div id="home-t-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;align-items:start;">
      <div class="home-t-slot" style="transition:opacity .6s ease;opacity:1;"></div>
      <div class="home-t-slot" style="transition:opacity .6s ease;opacity:1;"></div>
      <div class="home-t-slot" style="transition:opacity .6s ease;opacity:1;"></div>
    </div>
    <div id="home-t-dots" style="display:flex;gap:9px;justify-content:center;margin-top:28px;"></div>
    <div style="text-align:center;margin-top:40px;">
      <a data-reveal href={testimonialsPath} class="link-underline">{i.testimonials.more}</a>
    </div>
  </div>
</section>

<script type="application/json" id="home-t-data" set:html={JSON.stringify(items)}></script>
<script>
  import { initTestimonialCarousel } from '../scripts/testimonial-carousel.js';
  const dataEl = document.getElementById('home-t-data');
  const items = dataEl ? JSON.parse(dataEl.textContent) : [];
  initTestimonialCarousel({ gridSel: '#home-t-grid', slotSel: '.home-t-slot', dotsSel: '#home-t-dots', items, dotStyle: 'nested' });
</script>
