---
import { t, type Locale } from '../i18n/utils';

interface Props { locale: Locale; }

const { locale } = Astro.props;
const i = t(locale);
---

<a href="https://wa.me/patriciomx" target="_blank" rel="noopener" title={i.whatsappTitle} class="whatsapp-float" id="whatsapp-float">
  <img src="/uploads/whatsapp-icon.svg" loading="lazy" alt="WhatsApp" width="34" height="34" style="display:block;filter:brightness(0) invert(1);">
</a>

<style>
  .whatsapp-float {
    position: fixed; bottom: 26px; right: 26px; z-index: 60;
    width: 60px; height: 60px; border-radius: 50%; background: #25D366;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 10px 26px rgba(0,0,0,.22);
    will-change: opacity, transform;
    /* Not permanent: appears after scrolling, hides near the top. */
    opacity: 0; transform: translateY(20px) scale(.85); pointer-events: none;
    transition: transform .25s ease, opacity .35s ease;
  }
  .whatsapp-float.whatsapp-float--show {
    opacity: 1; transform: translateY(0) scale(1); pointer-events: auto;
  }
  .whatsapp-float.whatsapp-float--show:hover { transform: translateY(0) scale(1.08); }
</style>

<script is:inline>
  (function() {
    var wa = document.getElementById('whatsapp-float');
    if (!wa) return;
    window.addEventListener('scroll', function() {
      var y = window.scrollY || document.documentElement.scrollTop;
      wa.classList.toggle('whatsapp-float--show', y > 420);
    }, { passive: true });
  })();
</script>
