---
import { t, type Locale } from '../i18n/utils';

interface Props { locale: Locale; }

const { locale } = Astro.props;
const i = t(locale);
---

<a href="https://wa.me/patriciomx" target="_blank" rel="noopener" title={i.whatsappTitle} class="whatsapp-float">
  <img src="/uploads/whatsapp-icon.svg" loading="lazy" alt="WhatsApp" width="34" height="34" style="display:block;filter:brightness(0) invert(1);">
</a>

<style>
  .whatsapp-float {
    position: fixed; bottom: 26px; right: 26px; z-index: 60;
    width: 60px; height: 60px; border-radius: 50%; background: #25D366;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 10px 26px rgba(0,0,0,.22);
    animation: waPulse 2.6s infinite; will-change: box-shadow;
    transition: transform .25s ease;
  }
  .whatsapp-float:hover { transform: scale(1.08); }
</style>
