---
import { t, type Locale } from '../i18n/utils';

interface Props { locale: Locale; }

const { locale } = Astro.props;
const i = t(locale);
const privacyPath = locale === 'es' ? '/es/privacidad/' : '/en/privacy/';
const termsPath = locale === 'es' ? '/es/terminos/' : '/en/terms/';
const termsLabel = locale === 'es' ? 'Términos de servicio' : 'Terms of service';
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__mandala"></div>
  <div class="footer__inner">
    <div class="footer__columns">
      <div class="footer__contact">
        <h2 class="footer__title">{i.footer.contactTitle}</h2>
        <p class="footer__text">
          {i.footer.contactDesc}{' '}
          <a href="https://wa.me/patriciomx" target="_blank" rel="noopener" class="footer__wa-link">{i.footer.contactWhatsapp}</a>.
        </p>
        <a href="mailto:patricio@inessentia.mx" class="footer__email">patricio@inessentia.mx</a>
      </div>
      <div class="footer__right">
        <a href={privacyPath} class="footer__legal-link">{i.footer.privacy}</a>
        <a href={termsPath} class="footer__legal-link">{termsLabel}</a>
        <p class="footer__copyright">© 2025–{currentYear} Patricio Ruiz Abrín · <a href={privacyPath}>{i.footer.privacy}</a> · <a href={termsPath}>{termsLabel}</a></p>
        <div class="footer__social">
          <a href="https://www.instagram.com/neuve" target="_blank" rel="noopener" aria-label="Instagram" class="footer__social-link">
            <img src="/uploads/instagram-icon.svg" loading="lazy" alt="Instagram" width="27" height="27" style="display:block;filter:brightness(0) invert(1);">
          </a>
        </div>
      </div>
    </div>
    <div class="footer__bottom">
      <p class="footer__emergency">{i.footer.emergency}</p>
      <div class="footer__meta">
        <p class="footer__stock">{i.footer.stockCredit}</p>
        <p class="footer__version">V1.4</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative; overflow: hidden; background: var(--purple-d);
    color: #fff; padding: clamp(56px,8vw,96px) 32px clamp(34px,4vw,48px);
  }
  .footer__mandala {
    position: absolute; top: 0; left: -180px; width: 420px; height: 520px;
    opacity: .22; pointer-events: none;
    background: repeating-conic-gradient(#cdbce6 0deg .6deg, transparent .6deg 8deg);
    -webkit-mask: radial-gradient(circle, transparent 28%, #000 29%, #000 48%, transparent 49%);
    mask: radial-gradient(circle, transparent 28%, #000 29%, #000 48%, transparent 49%);
  }
  .footer__inner { position: relative; max-width: 1200px; margin: 0 auto; }
  .footer__columns {
    display: flex; gap: clamp(36px,6vw,90px); flex-wrap: wrap; justify-content: space-between;
  }
  .footer__contact { flex: 1 1 360px; min-width: 280px; }
  .footer__title {
    font-family: 'Zilla Slab', serif; font-weight: 700; color: var(--sand);
    font-size: clamp(34px,4.4vw,50px); margin: 0 0 22px;
  }
  .footer__text {
    font-size: 16px; line-height: 1.6; color: rgba(255,255,255,.82);
    margin: 0 0 22px; max-width: 42ch;
  }
  .footer__wa-link {
    color: #fff; font-weight: 600; text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,.5);
  }
  .footer__wa-link:hover { border-color: var(--sand); }
  .footer__email {
    display: inline-block; color: #fff; font-size: 19px; font-weight: 600;
    text-decoration: none; border-bottom: 1px solid rgba(255,255,255,.5);
    padding-bottom: 3px; margin-bottom: 28px;
  }
  .footer__email:hover { border-color: var(--sand); }
  .footer__right {
    flex: 0 1 300px; min-width: 240px; text-align: right;
    display: flex; flex-direction: column; align-items: flex-end; gap: 14px;
  }
  .footer__legal-link {
    color: rgba(255,255,255,.88); font-size: 17px; text-decoration: none;
  }
  .footer__legal-link:hover { color: var(--sand); }
  .footer__copyright {
    margin: 0; font-size: 13px; color: rgba(255,255,255,.65); text-align: right;
  }
  .footer__copyright a { color: rgba(255,255,255,.75); text-decoration: none; }
  .footer__copyright a:hover { color: var(--sand); }
  .footer__social { display: flex; gap: 14px; }
  .footer__social-link {
    display: flex; align-items: center; justify-content: center;
    opacity: .9; transition: opacity .25s, transform .25s;
  }
  .footer__social-link:hover { opacity: 1; transform: translateY(-2px); }
  .footer__bottom {
    border-top: 1px solid rgba(255,255,255,.18);
    margin-top: clamp(36px,5vw,56px); padding-top: 24px;
    display: flex; justify-content: space-between; gap: 18px; flex-wrap: wrap;
  }
  .footer__emergency {
    margin: 0; font-size: 13px; color: rgba(255,255,255,.55); max-width: 60ch;
  }
  .footer__meta {
    display: flex; flex-direction: column; align-items: flex-end; gap: 4px;
  }
  .footer__stock { margin: 0; font-size: 12px; color: rgba(255,255,255,.65); }
  .footer__version {
    margin: 0; font-size: 13px; color: rgba(255,255,255,.7); white-space: nowrap;
  }
</style>
