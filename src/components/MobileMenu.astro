---
import { t, navLinks, type Locale } from '../i18n/utils';

interface Props { locale: Locale; }

const { locale } = Astro.props;
const i = t(locale);
const links = navLinks(locale);
---

<div id="mob-menu">
  <button id="mob-close" aria-label={i.nav.closeMenu}>×</button>
  {links.map(link => (
    <a href={link.href}>{link.label}</a>
  ))}
  <a href="https://wa.me/patriciomx" target="_blank" rel="noopener" class="mob-cta">{i.nav.cta}</a>
  <div class="mob-social">
    <a href="https://www.instagram.com/neuve" target="_blank" rel="noopener" aria-label="Instagram"><img src="/uploads/instagram-icon.svg" alt="" width="20" height="20" /></a>
    <a href="https://www.facebook.com/neuve0/" target="_blank" rel="noopener" aria-label="Facebook"><img src="/uploads/facebook-icon.png" alt="" width="20" height="20" /></a>
    <a href="https://wa.me/patriciomx" target="_blank" rel="noopener" aria-label="WhatsApp"><img src="/uploads/whatsapp-icon.svg" alt="" width="20" height="20" /></a>
    <a href="https://www.linkedin.com/in/patricioruiz/" target="_blank" rel="noopener" aria-label="LinkedIn"><img src="/uploads/linkedin-icon.png" alt="" width="20" height="20" /></a>
  </div>
</div>
