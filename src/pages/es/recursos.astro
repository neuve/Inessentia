---
import Base from '../../layouts/Base.astro';
import { t } from '../../i18n/utils';
import { getResourcesGrid, getPost, postHref, tagLabels, tagOrder, tagKeysFor } from '../../data/posts';

const locale = 'es';
const i = t(locale);

const featuredIds = ['experiencia-somatica', 'sistemas-familiares-internos', 'core-energetica', 'tipos-de-terapia', 'que-esperar-de-la-terapia'];
const featured = featuredIds
  .map(id => getPost(id))
  .filter((p): p is NonNullable<typeof p> => Boolean(p))
  .map(p => ({
    href: postHref(locale, p.id),
    img: p.heroImage,
    pos: p.heroPosition,
    cat: p[locale].category,
    title: p[locale].title,
    blurb: p.cardBlurb?.[locale] ?? p[locale].description,
  }));

const tilePalettes = [
  { bg: 'var(--purple)', fg: '#fff', eb: 'var(--sand)', sub: 'rgba(255,255,255,.74)' },
  { bg: 'var(--wine)', fg: '#fff', eb: '#F0D9C4', sub: 'rgba(255,255,255,.82)' },
  { bg: 'var(--sand)', fg: 'var(--purple-d)', eb: 'var(--wine)', sub: '#5b4a2f' },
  { bg: 'var(--cream)', fg: 'var(--purple)', eb: 'var(--wine)', sub: '#4a443f' },
];
let tileIdx = 0;

const grid = getResourcesGrid().map(p => {
  const photo = !p.heroImage.endsWith('.svg');
  const pal = photo ? null : tilePalettes[tileIdx++ % tilePalettes.length];
  return {
    href: postHref(locale, p.id),
    img: p.cardImage ?? p.heroImage,
    pos: p.cardHeroPosition?.[locale] ?? p.heroPosition,
    cat: p[locale].category,
    title: p[locale].title,
    blurb: p.cardBlurb?.[locale] ?? p[locale].description,
    alt: p.cardAlt?.[locale] ?? p.heroAlt[locale],
    tags: tagKeysFor(p.id).join(' '),
    photo,
    pal,
  };
});

const pills = tagOrder.map(k => ({ key: k, label: tagLabels[k][locale] }));
---

<Base
  title="Recursos | Inessentia"
  description="Lecturas para apoyar tu proceso terapéutico y conocer mi filosofía y mis aproximaciones."
  altPath="/resources/"
>

  <!-- HERO: intro + destacado rotativo -->
  <section style="position:relative;overflow:hidden;padding:clamp(44px,6vw,64px) clamp(24px,5vw,52px) clamp(32px,4vw,48px);">
    <div style="position:absolute;inset:0;">
      {featured.map((f, k) => (
        <img src={f.img} data-rec-bg={k} alt="" data-parallax="0.08" data-parallax-max="24" style={`position:absolute;top:-10%;left:0;width:100%;height:120%;object-fit:cover;object-position:${f.pos};opacity:${k === 0 ? '1' : '0'};transition:opacity .6s ease;`}>
      ))}
      <div style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(46,22,72,.92) 0%,rgba(46,22,72,.8) 45%,rgba(46,22,72,.68) 100%);"></div>
    </div>
    <div style="position:relative;z-index:1;max-width:1240px;margin:0 auto;">
      <div style="position:absolute;top:0;right:clamp(24px,5vw,52px);display:flex;gap:7px;align-items:center;z-index:3;">
        {featured.map((_, k) => (
          <button type="button" data-rec-dot={k} aria-label={`Destacado ${k + 1}`} style={`height:9px;border-radius:99px;border:none;padding:0;cursor:pointer;transition:all .3s;width:${k === 0 ? '26px' : '9px'};background:${k === 0 ? '#fff' : 'rgba(255,255,255,.5)'};`}></button>
        ))}
      </div>
      <div class="rec-hero-grid">
        <!-- intro -->
        <div style="display:flex;flex-direction:column;justify-content:center;">
          <p data-reveal style="margin-bottom:14px;font-weight:700;font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:var(--sand);">{i.blog.label}</p>
          <h1 data-reveal style="font-family:'Zilla Slab',serif;font-weight:600;color:#fff;font-size:clamp(34px,4.6vw,52px);line-height:1.04;margin:0;">{i.blog.title}</h1>
          <p data-reveal style="font-size:clamp(16px,1.2vw,18px);line-height:1.6;color:rgba(255,255,255,.85);margin:20px 0 0;max-width:44ch;">{i.blog.subtitle}</p>
          <div data-reveal style="display:flex;flex-wrap:wrap;gap:9px;margin-top:28px;">
            <button type="button" data-rec-pill="all" style="background:var(--sand);color:var(--purple-d);border:1px solid var(--sand);padding:9px 17px;border-radius:99px;font-weight:700;font-size:12.5px;letter-spacing:.02em;cursor:pointer;white-space:nowrap;transition:all .2s;">Todos</button>
            {pills.map(p => (
              <button type="button" data-rec-pill={p.key} style="background:rgba(255,255,255,.14);color:#fff;border:1px solid rgba(255,255,255,.34);padding:9px 17px;border-radius:99px;font-weight:700;font-size:12.5px;letter-spacing:.02em;cursor:pointer;white-space:nowrap;transition:all .2s;">{p.label}</button>
            ))}
          </div>
        </div>
        <!-- destacado rotativo (solo texto, la foto es el fondo compartido) -->
        <div data-reveal style="position:relative;display:flex;flex-direction:column;justify-content:flex-end;min-height:400px;">
          {featured.map((f, k) => (
            <a href={f.href} data-rec-slide={k} style={`position:absolute;left:0;right:0;bottom:0;text-decoration:none;transition:opacity .6s ease;opacity:${k === 0 ? '1' : '0'};`}>
              <div style="display:inline-flex;background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.34);color:#fff;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;padding:8px 15px;border-radius:99px;margin-bottom:18px;">Destacado</div>
              <p style="margin:0 0 12px;font-weight:700;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--sand);">{f.cat}</p>
              <h2 style="font-family:'Zilla Slab',serif;font-weight:600;color:#fff;font-size:clamp(24px,2.6vw,34px);line-height:1.12;margin:0 0 14px;max-width:20ch;">{f.title}</h2>
              <p style="font-size:clamp(14px,1.1vw,16px);line-height:1.55;color:rgba(255,255,255,.86);margin:0 0 22px;max-width:46ch;">{f.blurb}</p>
              <span style="display:inline-flex;align-items:center;gap:9px;background:#fff;color:var(--purple);font-weight:700;font-size:13px;letter-spacing:.05em;text-transform:uppercase;padding:14px 26px;border-radius:99px;">{i.blog.readMore}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- GRID REVISTA -->
  <section style="background:var(--warm);padding:clamp(8px,2vw,20px) clamp(24px,5vw,52px) clamp(56px,8vw,88px);">
    <div style="max-width:1240px;margin:0 auto;">
      <div class="rec-grid">
        {grid.map(c => (
          c.photo ? (
            <a href={c.href} data-rec-item data-tags={c.tags} class="rec-card" style="break-inside:avoid;-webkit-column-break-inside:avoid;display:block;margin:0 0 22px;text-decoration:none;color:inherit;">
              <div style="background:#fff;border:1px solid #ece6d8;border-radius:20px;overflow:hidden;">
                <div style="height:190px;overflow:hidden;position:relative;"><img src={c.img} alt={c.alt} loading="lazy" data-parallax="0.10" data-parallax-max="14" style={`position:absolute;top:-14%;left:0;width:100%;height:128%;object-fit:cover;object-position:${c.pos};display:block;`}></div>
                <div style="padding:22px 22px 24px;">
                  <p style="margin:0 0 9px;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">{c.cat}</p>
                  <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.18;margin:0 0 10px;">{c.title}</h3>
                  <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0 0 14px;">{c.blurb}</p>
                  <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
                </div>
              </div>
            </a>
          ) : (
            <a href={c.href} data-rec-item data-tags={c.tags} class="rec-card" style="break-inside:avoid;-webkit-column-break-inside:avoid;display:block;margin:0 0 22px;text-decoration:none;color:inherit;">
              <div style={`background:${c.pal!.bg};border-radius:20px;padding:26px 24px;min-height:176px;display:flex;flex-direction:column;justify-content:flex-end;gap:11px;`}>
                <p style={`margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:${c.pal!.eb};`}>{c.cat}</p>
                <h3 style={`font-family:'Zilla Slab',serif;font-weight:600;color:${c.pal!.fg};font-size:22px;line-height:1.15;margin:0;`}>{c.title}</h3>
                <p style={`font-size:14px;line-height:1.55;color:${c.pal!.sub};margin:0;`}>{c.blurb}</p>
                <span style={`color:${c.pal!.fg};font-weight:700;font-size:13px;opacity:.92;`}>{i.blog.readMore}</span>
              </div>
            </a>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--purple);padding:clamp(64px,9vw,118px) 32px;text-align:center;">
    <div data-reveal style="max-width:760px;margin:0 auto;">
      <h2 style="font-family:'Zilla Slab',serif;font-weight:600;color:#fff;font-size:clamp(30px,4.6vw,54px);line-height:1.08;margin:0 0 22px;text-wrap:balance;">{i.cta.title}</h2>
      <p style="font-size:clamp(16px,1.2vw,19px);line-height:1.65;color:rgba(255,255,255,.82);margin:0 auto 36px;max-width:52ch;">{i.cta.desc}</p>
      <a href="https://wa.me/patriciomx" target="_blank" rel="noopener" class="btn-white">{i.cta.button}</a>
    </div>
  </section>

</Base>

<style>
  .rec-hero-grid { display:grid; grid-template-columns:0.86fr 1.14fr; gap:46px; align-items:stretch; }
  .rec-grid { column-count:3; column-gap:22px; }
  .rec-card { border-radius:20px; transition:transform .3s ease, box-shadow .3s ease; }
  .rec-card:hover { transform:translateY(-6px); box-shadow:0 22px 44px rgba(70,39,110,.16); }
  @media (max-width:1000px) { .rec-grid { column-count:2; } }
  @media (max-width:900px) { .rec-hero-grid { grid-template-columns:1fr; gap:26px; } }
  @media (max-width:640px) { .rec-grid { column-count:1; } }
</style>

<script is:inline>
  (function () {
    // Destacado rotativo
    var slides = Array.prototype.slice.call(document.querySelectorAll('[data-rec-slide]'));
    var dots = Array.prototype.slice.call(document.querySelectorAll('[data-rec-dot]'));
    var bgs = Array.prototype.slice.call(document.querySelectorAll('[data-rec-bg]'));
    var idx = 0, timer = null;
    function show(n) {
      idx = (n + slides.length) % slides.length;
      slides.forEach(function (s, k) { s.style.opacity = k === idx ? '1' : '0'; s.style.pointerEvents = k === idx ? 'auto' : 'none'; });
      dots.forEach(function (d, k) { d.style.width = k === idx ? '26px' : '9px'; d.style.background = k === idx ? '#fff' : 'rgba(255,255,255,.5)'; });
      bgs.forEach(function (b, k) { b.style.opacity = k === idx ? '1' : '0'; });
    }
    function start() { stop(); if (slides.length > 1) timer = setInterval(function () { show(idx + 1); }, 6000); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    dots.forEach(function (d, k) { d.addEventListener('click', function (e) { e.preventDefault(); show(k); start(); }); });
    if (slides.length) { show(0); start(); }

    // Filtro por categoría
    var pills = Array.prototype.slice.call(document.querySelectorAll('[data-rec-pill]'));
    var cards = Array.prototype.slice.call(document.querySelectorAll('[data-rec-item]'));
    function filter(key) {
      cards.forEach(function (c) {
        var tags = (c.getAttribute('data-tags') || '').split(' ');
        c.style.display = (key === 'all' || tags.indexOf(key) !== -1) ? '' : 'none';
      });
      pills.forEach(function (p) {
        var on = p.getAttribute('data-rec-pill') === key;
        p.style.background = on ? '#C2B07E' : 'rgba(255,255,255,.14)';
        p.style.color = on ? '#3C1F5E' : '#fff';
        p.style.borderColor = on ? '#C2B07E' : 'rgba(255,255,255,.34)';
      });
    }
    pills.forEach(function (p) { p.addEventListener('click', function () { filter(p.getAttribute('data-rec-pill')); }); });
  })();
</script>
