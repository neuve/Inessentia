---
import Base from '../../layouts/Base.astro';
import { t } from '../../i18n/utils';

const locale = 'es';
const i = t(locale);
---

<Base
  title="Recursos | Inessentia"
  description="Artículos y recursos para entender mejor la terapia antes de tu primera sesión."
  altPath="/resources/"
>

  <!-- HERO -->
  <section style="background:linear-gradient(180deg,var(--cream) 0%,var(--warm) 100%);padding:clamp(56px,8vw,96px) 32px clamp(40px,5vw,64px);">
    <div class="container">
      <p data-reveal class="label-section">{i.blog.label}</p>
      <h1 data-reveal style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:clamp(32px,4.5vw,52px);line-height:1.06;margin:0;">{i.blog.title}</h1>
    </div>
  </section>

  <!-- FEATURED POST -->
  <section class="section">
    <div class="container">
      <a data-reveal href="/es/blog/que-esperar-de-la-terapia/" class="card" style="display:grid;grid-template-columns:1fr 1fr;gap:0;text-decoration:none;color:inherit;margin-bottom:28px;">
        <div style="height:100%;min-height:260px;overflow:hidden;">
          <img src="/uploads/que-esperar-terapia.webp" width="1200" height="800" loading="lazy" alt="Retrato de una mujer joven de tez media con mirada cálida sosteniendo un corazón y mostrándoselo a la cámara" style="width:100%;height:100%;object-fit:cover;object-position:center 20%;display:block;">
        </div>
        <div style="padding:clamp(28px,3vw,44px);display:flex;flex-direction:column;justify-content:center;gap:14px;">
          <p style="margin:0;font-weight:700;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--wine);">Proceso terapéutico</p>
          <h2 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:clamp(22px,2.5vw,32px);line-height:1.15;margin:0;">¿Qué esperar de la terapia?</h2>
          <p style="font-size:15px;line-height:1.6;color:#4a443f;margin:0;">Cómo se conjugan la relación terapéutica, las técnicas y el tiempo en un proceso real.</p>
          <span style="color:var(--wine);font-weight:700;font-size:14px;">{i.blog.readMore}</span>
        </div>
      </a>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:26px;">

        <a data-reveal href="/es/blog/primera-cita/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/primera-cita-terapia.webp" width="2048" height="2048" loading="lazy" alt="Sala de terapia vacía con dos sillones uno frente al otro, luz cálida de tarde" style="width:100%;height:100%;object-fit:cover;object-position:center 35%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Primera sesión</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">¿Cómo suele ser la primera cita?</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Qué pasa, cuánto dura, qué llevarte.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/cuando-es-buen-momento/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/buen-momento-pareja.webp" width="2048" height="2048" loading="lazy" alt="Persona sentada junto a una ventana en la mañana sosteniendo una taza, ambiente contemplativo" style="width:100%;height:100%;object-fit:cover;object-position:center 55%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Bienestar</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">¿Cuándo es buen momento para empezar terapia?</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Las señales que vale la pena escuchar.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/tipos-de-terapia/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/tipos-terapia.webp" width="1200" height="800" loading="lazy" alt="Fotografía con acercamiento a un par de manos que se tocan cálida y firmemente" style="width:100%;height:100%;object-fit:cover;object-position:center 55%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Aproximaciones terapéuticas</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Tipos de terapia: cómo trabajo en sesión</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Cuatro aproximaciones que integro.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/terapia-corporal/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/terapia-corporal.webp" width="2048" height="2048" loading="lazy" alt="Acercamiento a una mano abierta apoyada sobre una rodilla, luz natural" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Aproximaciones terapéuticas</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">¿Qué es la terapia corporal?</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">El cuerpo guarda lo que la mente no alcanza a procesar.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/teoria-polivagal/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-teoria-polivagal.svg" width="1200" height="800" loading="lazy" alt="Ondas concéntricas en calma sobre agua quieta, luz dorada" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Sistema nervioso</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Teoría Polivagal: el sistema nervioso como brújula</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Por qué reaccionamos como reaccionamos.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/experiencia-somatica/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-experiencia-somatica.svg" width="1200" height="800" loading="lazy" alt="Venado en un claro de bosque, luz moteada entre los árboles" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Aproximaciones terapéuticas</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Experiencia Somática (SE)</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Completar ciclos de defensa interrumpidos.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/sistemas-familiares-internos/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-sistemas-familiares-internos.svg" width="1200" height="800" loading="lazy" alt="Reflejos múltiples del cielo en charcos de agua sobre una calle" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Aproximaciones terapéuticas</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Sistemas Familiares Internos (IFS)</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Conocer las partes que te habitan.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/tapping-eft/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-tapping-eft.svg" width="1200" height="800" loading="lazy" alt="Acercamiento a unas yemas de los dedos tocando suavemente la clavícula" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Aproximaciones terapéuticas</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Tapping / EFT</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Cuando el cuerpo recibe la señal de que ya estás a salvo.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/core-energetica/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-core-energetica.svg" width="1200" height="800" loading="lazy" alt="Figura humana de espaldas frente a una ventana grande con luz de mañana" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Aproximaciones terapéuticas</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Core Energética: el cuerpo como archivo de tu historia</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">El cuerpo como archivo emocional.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/ansiedad-somatica/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-ansiedad-somatica.svg" width="1200" height="800" loading="lazy" alt="Manos entrelazadas sobre el pecho, respiración consciente" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Bienestar</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Siento ansiedad en el cuerpo, no solo en la mente</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Cómo el cuerpo registra la ansiedad antes que la mente le ponga nombre.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/duelo-somatico/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-duelo-somatico.svg" width="1200" height="800" loading="lazy" alt="Pluma blanca flotando suavemente en el aire" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Bienestar</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Duelo: cuando la pérdida se queda en el cuerpo</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">El duelo no se resuelve — se integra.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/estres-cronico/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-estres-cronico.svg" width="1200" height="800" loading="lazy" alt="Reloj de arena junto a una ventana, luz tensa de mediodía" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Sistema nervioso</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Qué es el estrés crónico y cómo afecta al cuerpo</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Por qué relajarse no siempre es suficiente.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/patrones-de-pareja/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-patrones-de-pareja.svg" width="1200" height="800" loading="lazy" alt="Dos siluetas en espejo, movimiento circular" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Bienestar</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Mi pareja y yo repetimos siempre el mismo patrón</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Reconocer el ciclo es el primer paso para salir de él.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/psicologo-psicoterapeuta-psiquiatra/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-psicologo-psicoterapeuta-psiquiatra.svg" width="1200" height="800" loading="lazy" alt="Brújula sobre un mapa, luz cálida de escritorio" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Proceso terapéutico</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Diferencia entre psicólogo, psicoterapeuta y psiquiatra</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">La pregunta más frecuente de quien busca ayuda por primera vez.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/regulacion-sistema-nervioso/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-regulacion-sistema-nervioso.svg" width="1200" height="800" loading="lazy" alt="Balanza suspendida en equilibrio, luz suave" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Sistema nervioso</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Qué es la regulación del sistema nervioso y por qué importa</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">No es calmarse con fuerza de voluntad.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/es/blog/terapia-adolescentes/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-terapia-adolescentes.svg" width="1200" height="800" loading="lazy" alt="Brote verde emergiendo de la tierra, luz de mañana" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
