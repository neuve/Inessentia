---
import Base from '../../layouts/Base.astro';
import Img from '../../components/Img.astro';
import { t } from '../../i18n/utils';
import { getResourcesGrid, getPost, postHref } from '../../data/posts';

const locale = 'en';
const i = t(locale);

// Flagship posts for the cinematic hero (1b order).
const featuredIds = ['que-esperar-de-la-terapia', 'experiencia-somatica', 'sistemas-familiares-internos', 'tipos-de-terapia', 'teoria-polivagal'];
const featured = featuredIds
  .map(id => getPost(id))
  .filter((p): p is NonNullable<typeof p> => Boolean(p))
  .map(p => ({
    href: postHref(locale, p.id),
    img: p.heroImage,
    pos: p.heroPosition,
    cat: p[locale].category,
    title: p[locale].title,
  }));

// Filter by editorial category (1b order). "All" + the 5 real categories.
const catOrder = ['Therapeutic approaches', 'Nervous system', 'Wellbeing', 'Therapeutic process', 'First session'];
const cats = [{ key: 'all', label: 'All' }, ...catOrder.map(c => ({ key: c, label: c }))];

// Palette for solid-color tiles (rotates through 4 combos, 1b).
const tilePalettes = [
  { bg: 'var(--purple)', fg: '#fff', eb: '#E6D2B4', sub: 'rgba(255,255,255,.74)' },
  { bg: 'var(--purple-d)', fg: '#fff', eb: 'var(--sand)', sub: 'rgba(255,255,255,.72)' },
  { bg: 'var(--wine)', fg: '#fff', eb: '#EAD9C4', sub: 'rgba(255,255,255,.78)' },
  { bg: 'var(--sand)', fg: '#2e1b12', eb: '#5a3a1e', sub: 'rgba(40,30,20,.72)' },
];
let tileIdx = 0;

const grid = getResourcesGrid().map((p, k) => {
  const photo = !p.heroImage.endsWith('.svg');
  const pal = photo ? null : tilePalettes[tileIdx++ % tilePalettes.length];
  return {
    href: postHref(locale, p.id),
    img: p.cardImage ?? p.heroImage,
    pos: p.cardHeroPosition?.[locale] ?? p.heroPosition,
    cat: p[locale].category,
    title: p[locale].title,
    blurb: p.cardBlurb?.[locale] ?? p[locale].description,
    alt: p.cardAlt?.[locale] ?? p.heroAlt[locale],
    video: p.cardVideo,
    photo,
    pal,
    big: k % 5 === 0, // every 5th tile is "large"
  };
});
---

<Base
  title="Resources | Inessentia"
  description="Readings to support your therapeutic process and to get to know my philosophy and my approaches."
  altPath="/recursos/"
>

  <!-- CINEMATIC HERO: intro (top) + rotating featured (bottom) over a full-bleed banner -->
  <section class="rec-hero" data-nav-overlay>
    {featured.map((f, k) => (
      <Img src={f.img} sizes="100vw" loading="eager" data-rec-bg={k} alt="" style={`position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:${f.pos};opacity:${k === 0 ? '1' : '0'};transition:opacity .7s ease;`} />
    ))}
    <div class="rec-hero-overlay"></div>

    <!-- fixed section intro -->
    <div class="rec-hero-intro">
      <p style="margin:0 0 14px;font-weight:700;font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:#E6D2B4;">{i.blog.label}</p>
      <h1 style="font-family:'Bitter',serif;font-weight:700;color:#fff;font-size:clamp(34px,4.6vw,56px);line-height:1.0;margin:0;max-width:15ch;">{i.blog.title}</h1>
      <p style="font-size:clamp(15px,1.3vw,18px);line-height:1.6;color:rgba(255,255,255,.82);margin:20px 0 0;max-width:50ch;">{i.blog.subtitle}</p>
    </div>

    <!-- rotating featured post -->
    <div class="rec-hero-feature">
      <div style="flex:1 1 auto;max-width:60%;min-width:0;position:relative;">
        <div style="height:1px;background:rgba(255,255,255,.25);margin-bottom:22px;"></div>
        {featured.map((f, k) => (
          <a href={f.href} data-rec-slide={k} style={`display:block;text-decoration:none;transition:opacity .5s ease;opacity:${k === 0 ? '1' : '0'};${k === 0 ? '' : 'position:absolute;left:0;right:0;bottom:0;pointer-events:none;'}`}>
            <p style="margin:0 0 10px;font-weight:700;font-size:11.5px;letter-spacing:.15em;text-transform:uppercase;color:#E6D2B4;">Featured · {f.cat}</p>
            <h2 style="font-family:'Bitter',serif;font-weight:700;color:#fff;font-size:clamp(24px,2.6vw,32px);line-height:1.12;margin:0 0 16px;max-width:26ch;">{f.title}</h2>
            <span style="display:inline-flex;align-items:center;gap:9px;background:#fff;color:var(--purple);font-weight:700;font-size:13px;letter-spacing:.05em;text-transform:uppercase;padding:14px 26px;border-radius:99px;">{i.blog.readMore}</span>
          </a>
        ))}
      </div>
      <div style="display:flex;gap:7px;align-items:center;padding-bottom:6px;flex:0 0 auto;">
        {featured.map((_, k) => (
          <button type="button" data-rec-dot={k} aria-label={`Featured ${k + 1}`} style={`height:9px;border-radius:99px;border:none;padding:0;cursor:pointer;transition:all .3s;width:${k === 0 ? '26px' : '9px'};background:${k === 0 ? '#fff' : 'rgba(255,255,255,.45)'};`}></button>
        ))}
      </div>
    </div>
  </section>

  <!-- CATEGORY FILTER (pills) -->
  <div style="background:var(--cream-2);padding:24px clamp(24px,5vw,52px) 6px;border-bottom:1px solid #e2dccc;">
    <div style="max-width:1320px;margin:0 auto;display:flex;flex-wrap:wrap;gap:9px;">
      {cats.map((c, k) => (
        <button type="button" data-rec-pill={c.key}
          style={`background:${k === 0 ? 'var(--purple)' : '#fff'};color:${k === 0 ? '#fff' : '#5a5048'};border:1px solid ${k === 0 ? 'var(--purple)' : '#e4dece'};padding:9px 17px;border-radius:99px;font-weight:700;font-size:12.5px;letter-spacing:.02em;cursor:pointer;white-space:nowrap;transition:all .2s;`}>{c.label}</button>
      ))}
    </div>
  </div>

  <!-- DENSE MOSAIC (masonry, 4 columns) -->
  <section style="background:var(--cream-2);padding:34px clamp(24px,5vw,52px) 58px;">
    <div style="max-width:1320px;margin:0 auto;">
      <div class="rec-grid">
        {grid.map(c => (
          c.photo ? (
            <a href={c.href} data-rec-item data-cat={c.cat} class="rec-card" style="break-inside:avoid;-webkit-column-break-inside:avoid;display:block;margin:0 0 20px;text-decoration:none;color:inherit;">
              <div style="background:#fff;border:1px solid #e6ddca;border-radius:18px;overflow:hidden;">
                <div style={`height:${c.big ? '300' : '208'}px;overflow:hidden;position:relative;`}>
                  <Img src={c.img} sizes="(max-width:640px) 100vw, 400px" alt={c.alt} style={`width:100%;height:100%;object-fit:cover;object-position:${c.pos};display:block;`} />
                  {c.video && (
                    <video class="rec-card-video" muted loop playsinline preload="none" style={`position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:${c.pos};`}>
                      <source src={c.video.webm} type="video/webm" />
                      <source src={c.video.mp4} type="video/mp4" />
                    </video>
                  )}
                </div>
                <div style="padding:18px 18px 20px;">
                  <p style="margin:0 0 8px;font-weight:700;font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">{c.cat}</p>
                  <h3 style={`font-family:'Bitter',serif;font-weight:700;color:var(--purple);font-size:${c.big ? '24px' : '19px'};line-height:1.18;margin:0 0 9px;`}>{c.title}</h3>
                  <p style="font-size:13px;line-height:1.55;color:#4a443f;margin:0;">{c.blurb}</p>
                </div>
              </div>
            </a>
          ) : (
            <a href={c.href} data-rec-item data-cat={c.cat} class="rec-card" style="break-inside:avoid;-webkit-column-break-inside:avoid;display:block;margin:0 0 20px;text-decoration:none;color:inherit;">
              <div style={`background:${c.pal!.bg};border-radius:18px;padding:${c.big ? '38px 30px 34px' : '26px 24px 28px'};min-height:158px;display:flex;flex-direction:column;justify-content:flex-end;gap:10px;`}>
                <p style={`margin:0;font-weight:700;font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:${c.pal!.eb};`}>{c.cat}</p>
                <h3 style={`font-family:'Bitter',serif;font-weight:700;color:${c.pal!.fg};font-size:${c.big ? '28px' : '21px'};line-height:1.15;margin:0;`}>{c.title}</h3>
                <p style={`font-size:13px;line-height:1.5;color:${c.pal!.sub};margin:0;`}>{c.blurb}</p>
              </div>
            </a>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--purple);padding:clamp(64px,9vw,118px) 32px;text-align:center;">
    <div data-reveal style="max-width:760px;margin:0 auto;">
      <h2 style="font-family:'Bitter',serif;font-weight:700;color:#fff;font-size:clamp(30px,4.6vw,54px);line-height:1.08;margin:0 0 22px;text-wrap:balance;">{i.cta.title}</h2>
      <p style="font-size:clamp(16px,1.2vw,19px);line-height:1.65;color:rgba(255,255,255,.82);margin:0 auto 36px;max-width:52ch;">{i.cta.desc}</p>
      <a href="https://wa.me/patriciomx" target="_blank" rel="noopener" class="btn-white">{i.cta.button}</a>
    </div>
  </section>

</Base>

<style>
  .rec-hero { position:relative; overflow:hidden; height:calc(clamp(540px,64vw,600px) + var(--nav-h)); width:100%; }
  .rec-hero-overlay { position:absolute; inset:0; background:linear-gradient(118deg,rgba(46,22,72,.95) 0%,rgba(46,22,72,.82) 38%,rgba(46,22,72,.34) 72%,rgba(46,22,72,.12) 100%); }
  .rec-hero-intro { position:absolute; top:calc(clamp(32px,5vw,46px) + var(--nav-h)); left:clamp(24px,5vw,52px); right:clamp(24px,5vw,52px); z-index:1; }
  .rec-hero-feature { position:absolute; left:clamp(24px,5vw,52px); right:clamp(24px,5vw,52px); bottom:40px; z-index:1; display:flex; justify-content:space-between; align-items:flex-end; gap:28px; }
  .rec-grid { column-count:4; column-gap:20px; }
  .rec-card { border-radius:18px; transition:transform .3s ease, box-shadow .3s ease; }
  .rec-card:hover { transform:translateY(-6px); box-shadow:0 22px 44px rgba(60,31,94,.24); }
  .rec-card-video { opacity:0; transition:opacity .35s ease; }
  .rec-card:hover .rec-card-video { opacity:1; }
  @media (max-width:1200px) { .rec-grid { column-count:3; } }
  @media (max-width:820px) { .rec-grid { column-count:2; } .rec-hero-feature > div:first-child { max-width:100%; } }
  @media (max-width:560px) { .rec-grid { column-count:1; } .rec-hero-feature { flex-direction:column; align-items:flex-start; gap:16px; } }
</style>

<script is:inline>
  (function () {
    // Card video on hover
    Array.prototype.slice.call(document.querySelectorAll('.rec-card-video')).forEach(function (v) {
      var card = v.closest('.rec-card');
      if (!card) return;
      card.addEventListener('mouseenter', function () { v.play().catch(function () {}); });
      card.addEventListener('mouseleave', function () { v.pause(); v.currentTime = 0; });
    });

    // Rotating featured
    var slides = Array.prototype.slice.call(document.querySelectorAll('[data-rec-slide]'));
    var dots = Array.prototype.slice.call(document.querySelectorAll('[data-rec-dot]'));
    var bgs = Array.prototype.slice.call(document.querySelectorAll('[data-rec-bg]'));
    var idx = 0, timer = null;
    function show(n) {
      idx = (n + slides.length) % slides.length;
      slides.forEach(function (s, k) {
        s.style.opacity = k === idx ? '1' : '0';
        s.style.pointerEvents = k === idx ? 'auto' : 'none';
      });
      dots.forEach(function (d, k) { d.style.width = k === idx ? '26px' : '9px'; d.style.background = k === idx ? '#fff' : 'rgba(255,255,255,.45)'; });
      bgs.forEach(function (b, k) { b.style.opacity = k === idx ? '1' : '0'; });
    }
    function start() { stop(); if (slides.length > 1) timer = setInterval(function () { show(idx + 1); }, 5500); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    dots.forEach(function (d, k) { d.addEventListener('click', function (e) { e.preventDefault(); show(k); start(); }); });
    if (slides.length) { show(0); start(); }

    // Filter by editorial category
    var pills = Array.prototype.slice.call(document.querySelectorAll('[data-rec-pill]'));
    var cards = Array.prototype.slice.call(document.querySelectorAll('[data-rec-item]'));
    function filter(key) {
      cards.forEach(function (c) {
        c.style.display = (key === 'all' || c.getAttribute('data-cat') === key) ? '' : 'none';
      });
      pills.forEach(function (p) {
        var on = p.getAttribute('data-rec-pill') === key;
        p.style.background = on ? '#46276E' : '#fff';
        p.style.color = on ? '#fff' : '#5a5048';
        p.style.borderColor = on ? '#46276E' : '#e4dece';
      });
    }
    pills.forEach(function (p) { p.addEventListener('click', function () { filter(p.getAttribute('data-rec-pill')); }); });
  })();
</script>
