---
import Base from '../../layouts/Base.astro';
import { t } from '../../i18n/utils';

const locale = 'en';
const i = t(locale);
---

<Base
  title="Resources | Inessentia"
  description="Articles and resources to better understand therapy before your first session."
  altPath="/recursos/"
>

  <section style="background:linear-gradient(180deg,var(--cream) 0%,var(--warm) 100%);padding:clamp(56px,8vw,96px) 32px clamp(40px,5vw,64px);">
    <div class="container">
      <p data-reveal class="label-section">{i.blog.label}</p>
      <h1 data-reveal style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:clamp(32px,4.5vw,52px);line-height:1.06;margin:0;">{i.blog.title}</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <a data-reveal href="/en/blog/what-to-expect/" class="card" style="display:grid;grid-template-columns:1fr 1fr;gap:0;text-decoration:none;color:inherit;margin-bottom:28px;">
        <div style="height:100%;min-height:260px;overflow:hidden;">
          <img src="/uploads/que-esperar-terapia.webp" width="1200" height="800" loading="lazy" alt="Portrait of a young woman with a warm gaze holding a heart-shaped object and showing it to the camera" style="width:100%;height:100%;object-fit:cover;object-position:center 20%;display:block;">
        </div>
        <div style="padding:clamp(28px,3vw,44px);display:flex;flex-direction:column;justify-content:center;gap:14px;">
          <p style="margin:0;font-weight:700;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--wine);">Therapeutic process</p>
          <h2 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:clamp(22px,2.5vw,32px);line-height:1.15;margin:0;">What to expect from therapy?</h2>
          <p style="font-size:15px;line-height:1.6;color:#4a443f;margin:0;">How the therapeutic relationship, techniques and time come together in a real process.</p>
          <span style="color:var(--wine);font-weight:700;font-size:14px;">{i.blog.readMore}</span>
        </div>
      </a>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:26px;">
        <a data-reveal href="/en/blog/first-session/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/primera-cita-terapia.webp" width="1200" height="800" loading="lazy" alt="Empty therapy room with two armchairs facing each other, warm afternoon light" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">First session</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">What's a first session usually like?</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">What happens, how long it lasts, what to bring.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/good-time-to-start/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/buen-momento-pareja.webp" width="1200" height="800" loading="lazy" alt="Person sitting by a window in morning light, holding a cup, contemplative mood" style="width:100%;height:100%;object-fit:cover;object-position:center 55%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Wellbeing</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">When is a good time to start therapy?</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">The signs worth listening to.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/types-of-therapy/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/tipos-terapia.webp" width="1200" height="800" loading="lazy" alt="Close-up photograph of a pair of hands touching each other warmly and firmly" style="width:100%;height:100%;object-fit:cover;object-position:center 25%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Therapeutic approaches</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Types of therapy: how I work in session</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Four approaches I integrate.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/body-based-therapy/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/terapia-corporal.webp" width="2048" height="2048" loading="lazy" alt="Close-up of a hand resting open on a knee, natural light" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Therapeutic approaches</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">What is body-based therapy?</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">The body holds what the mind can't fully process.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/polyvagal-theory/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-teoria-polivagal.svg" width="1200" height="800" loading="lazy" alt="Calm concentric waves on still water, golden light" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Nervous system</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Polyvagal Theory: the nervous system as a compass</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Why we react the way we react.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/somatic-experiencing/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-experiencia-somatica.svg" width="1200" height="800" loading="lazy" alt="A deer in a forest clearing, dappled light through trees" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Therapeutic approaches</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Somatic Experiencing (SE)</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Completing interrupted defense cycles.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/internal-family-systems/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-sistemas-familiares-internos.svg" width="1200" height="800" loading="lazy" alt="Multiple reflections of the sky in puddles on a quiet street" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Therapeutic approaches</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Internal Family Systems (IFS)</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Getting to know the parts that live in you.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/tapping-eft/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-tapping-eft.svg" width="1200" height="800" loading="lazy" alt="Close-up of fingertips gently touching a collarbone" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Therapeutic approaches</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Tapping / EFT</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">When the body gets the signal that you're safe now.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/core-energetics/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-core-energetica.svg" width="1200" height="800" loading="lazy" alt="A human figure from behind, standing before a large window with morning light" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Therapeutic approaches</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Core Energetics: the body as an archive of your history</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">The body as an emotional archive.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>
        <a data-reveal href="/en/blog/somatic-anxiety/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-ansiedad-somatica.svg" width="1200" height="800" loading="lazy" alt="Hands clasped over the chest, conscious breathing" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Wellbeing</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">I feel anxiety in my body, not just my mind</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">How the body registers anxiety before the mind can name it.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/somatic-grief/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-duelo-somatico.svg" width="1200" height="800" loading="lazy" alt="White feather floating gently in the air" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Wellbeing</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Grief: when loss stays in the body</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Grief doesn't resolve — it integrates.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/chronic-stress/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-estres-cronico.svg" width="1200" height="800" loading="lazy" alt="Hourglass by a window, tense midday light" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Nervous system</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">What chronic stress is and how it affects the body</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Why relaxing isn't always enough.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/couples-patterns/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-patrones-de-pareja.svg" width="1200" height="800" loading="lazy" alt="Two mirrored silhouettes, circular motion" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Wellbeing</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">My partner and I keep repeating the same pattern</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Recognizing the cycle is the first step out of it.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/psychologist-therapist-psychiatrist/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-psicologo-psicoterapeuta-psiquiatra.svg" width="1200" height="800" loading="lazy" alt="Compass on a map, warm desk light" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Therapeutic process</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Psychologist, psychotherapist, or psychiatrist?</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">The most frequent question from anyone seeking help for the first time.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/nervous-system-regulation/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-regulacion-sistema-nervioso.svg" width="1200" height="800" loading="lazy" alt="Balance scale suspended in equilibrium, soft light" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Nervous system</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">What nervous system regulation means and why it matters</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">It isn't calming down through willpower.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/teen-therapy/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-terapia-adolescentes.svg" width="1200" height="800" loading="lazy" alt="Green sprout emerging from the soil, morning light" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Therapeutic process</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Therapy for teenagers: when and how</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">One of the deepest neurological reorganizations of a lifetime.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/individual-or-couples-therapy/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-terapia-individual-o-pareja.svg" width="1200" height="800" loading="lazy" alt="Two paths splitting in a bright forest" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Therapeutic process</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">Do I need individual or couples therapy?</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">The answer is almost never binary.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/in-person-vs-online-therapy/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-terapia-presencial-vs-online.svg" width="1200" height="800" loading="lazy" alt="Lit screen beside an empty chair in a warm room" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Therapeutic process</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">In-person vs online therapy: which works better?</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">What the evidence says and how I think about the choice.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/undiagnosed-trauma/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="height:184px;overflow:hidden;"><img src="/uploads/placeholder-trauma-sin-diagnosticar.svg" width="1200" height="800" loading="lazy" alt="Pensive silhouette looking through a fogged-up window" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"></div>
          <div style="padding:24px 24px 26px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <p style="margin:0;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);">Wellbeing</p>
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:20px;line-height:1.2;margin:0;">I can't stop thinking about something that happened</h3>
            <p style="font-size:14px;line-height:1.6;color:#4a443f;margin:0;flex:1;">Trauma is what stays in the body, not what occurred.</p>
            <span style="color:var(--wine);font-weight:700;font-size:13px;">{i.blog.readMore}</span>
          </div>
        </a>

      </div>
    </div>
  </section>

