---
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { t } from '../../i18n/utils';
import { personSchema } from '../../data/person';

const locale = 'en';
const i = t(locale);

const schema = personSchema(locale);
---

<Base
  title="About me | Patricio Ruiz Abrín, psychosomatic and systemic therapist"
  description="Meet Patricio Ruiz Abrín, a psychotherapist with a psychosomatic and systemic approach in Mexico City and online: his training, his perspective, and how he accompanies each process."
  altPath="/sobre-mi/"
  ogImage="/uploads/og/about-me.webp"
  schema={schema}
>

  <!-- HERO -->
  <SiteHeader
    eyebrow="Psychotherapist · Mexico City and online"
    title="I'm Patricio Ruiz Abrín, a systemic and psychosomatic therapist."
    photo="/uploads/terapia-hero.webp"
    photoAlt="Patricio Ruiz Abrín, psychotherapist"
    ctaLabel="Book your first session"
    ctaHref="https://wa.me/patriciomx"
  >
    <p><strong>Feel at home in yourself.</strong></p>
    <p>I help you reconnect with your intuition, your instinct, and your ability to self-regulate. A space of presence, curiosity, containment, and experimentation for your growth, with a humanistic and relational approach that integrates mind, emotion, and body.</p>
  </SiteHeader>

  <!-- APPROACH -->
  <section id="enfoque" class="section" style="background:var(--cream-2);">
    <div style="max-width:1000px;margin:0 auto;padding:0 32px;">
      <p data-reveal class="label-section">My approach</p>
      <h2 data-reveal class="heading-section">Commitment, responsibility, and experience</h2>
      <h3 data-reveal style="font-family:'Zilla Slab',serif;font-weight:500;color:var(--wine);font-size:clamp(19px,2vw,24px);margin:0 0 28px;">How I work</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:28px 48px;">
        <p data-reveal class="body-text" style="margin:0;grid-column:1 / -1;">I work with adolescents and adults in individual therapy, couples, families, organizations, and growth groups. My approach integrates body psychotherapy and a trauma-informed perspective: I believe the body is our primary resource for being in the world, and that it holds both our wounds and the answers we need to live better.</p>
      </div>
      <div data-reveal style="margin-top:36px;">
        <p style="font-weight:700;font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink);margin:0 0 16px;">Modalities I integrate</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <span style="background:var(--purple);color:#fff;font-weight:600;font-size:13px;padding:8px 18px;border-radius:999px;">Somatic Experiencing (SE)</span>
          <span style="background:var(--purple);color:#fff;font-weight:600;font-size:13px;padding:8px 18px;border-radius:999px;">Internal Family Systems (IFS)</span>
          <span style="background:var(--purple);color:#fff;font-weight:600;font-size:13px;padding:8px 18px;border-radius:999px;">Tapping (EFT)</span>
          <span style="background:var(--purple);color:#fff;font-weight:600;font-size:13px;padding:8px 18px;border-radius:999px;">Core Energetics</span>
          <span style="background:var(--purple);color:#fff;font-weight:600;font-size:13px;padding:8px 18px;border-radius:999px;">Reiki</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TRAINING -->
  <section id="formacion" class="section">
    <div style="max-width:1100px;margin:0 auto;padding:0 32px;">
      <p data-reveal class="label-section">Background</p>
      <h2 data-reveal class="heading-section" style="margin-bottom:48px;">My training and experience</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(300px,100%),1fr));gap:40px;">

        <div data-reveal>
          <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--wine);font-size:20px;margin:0 0 22px;padding-bottom:12px;border-bottom:2px solid var(--cream);">Degrees</h3>
          <div style="display:flex;flex-direction:column;gap:16px;">
            <div>
              <p style="margin:0 0 3px;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--sand-d);">2015</p>
              <p style="margin:0;font-size:15px;font-weight:600;color:var(--ink);">Architect</p>
              <p style="margin:0;font-size:14px;color:#6a6460;">Facultad de Arquitectura, UNAM</p>
            </div>
            <div>
              <p style="margin:0 0 3px;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--sand-d);">2025-26 · in progress</p>
              <p style="margin:0;font-size:15px;font-weight:600;color:var(--ink);">Master's in Systemic Family Therapy</p>
              <p style="margin:0;font-size:14px;color:#6a6460;">Instituto Crisol</p>
            </div>
          </div>
        </div>

        <div data-reveal>
          <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--wine);font-size:20px;margin:0 0 22px;padding-bottom:12px;border-bottom:2px solid var(--cream);">Specialized training</h3>
          <div style="display:flex;flex-direction:column;gap:14px;">
            <div>
              <p style="margin:0 0 2px;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--sand-d);">2015-18</p>
              <p style="margin:0;font-size:15px;color:var(--ink);line-height:1.4;">Core Energetics Practitioner + Postgraduate — Instituto Corpore</p>
            </div>
            <div>
              <p style="margin:0 0 2px;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--sand-d);">2019-20</p>
              <p style="margin:0;font-size:15px;color:var(--ink);line-height:1.4;">Person-Centered Approach Specialization — IHPG</p>
            </div>
            <div>
              <p style="margin:0 0 2px;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--sand-d);">2022-24</p>
              <p style="margin:0;font-size:15px;color:var(--ink);line-height:1.4;"><a href="https://portal.traumahealing.org/s/searchdirectory" target="_blank" rel="noopener" style="color:inherit;text-decoration:none;font-weight:600;">Somatic Experiencing Practitioner</a> — <a href="https://experienciasomaticamexico.com/terapeutas/patricio-michel-ruiz-abrin/" target="_blank" rel="noopener" style="color:inherit;text-decoration:none;font-weight:600;">Experiencia Somática México</a></p>
            </div>
            <div>
              <p style="margin:0 0 2px;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--sand-d);">Ongoing studies</p>
              <ul style="margin:0;padding-left:18px;display:flex;flex-direction:column;gap:4px;list-style:disc;">
                <li style="font-size:15px;color:var(--ink);line-height:1.4;">IFS</li>
                <li style="font-size:15px;color:var(--ink);line-height:1.4;">EFT</li>
                <li style="font-size:15px;color:var(--ink);line-height:1.4;">Exceptional Marriage</li>
                <li style="font-size:15px;color:var(--ink);line-height:1.4;">Reiki Usui Level 3</li>
              </ul>
            </div>
          </div>
        </div>

        <div data-reveal>
          <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--wine);font-size:20px;margin:0 0 22px;padding-bottom:12px;border-bottom:2px solid var(--cream);">Clinical experience</h3>
          <div style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:flex-start;gap:14px;">
              <span style="font-family:'Zilla Slab',serif;font-weight:700;font-size:32px;color:var(--purple);line-height:1;flex:none;">10</span>
              <p style="margin:0;font-size:15px;color:var(--ink);line-height:1.5;">years working with adolescents and adults in individual therapy</p>
            </div>
            <div style="display:flex;align-items:flex-start;gap:14px;">
              <span style="font-family:'Zilla Slab',serif;font-weight:700;font-size:32px;color:var(--purple);line-height:1;flex:none;">6</span>
              <p style="margin:0;font-size:15px;color:var(--ink);line-height:1.5;">years working with couples in relational therapy</p>
            </div>
            <div style="display:flex;align-items:flex-start;gap:14px;">
              <span style="font-family:'Zilla Slab',serif;font-weight:700;font-size:32px;color:var(--purple);line-height:1;flex:none;">2</span>
              <p style="margin:0;font-size:15px;color:var(--ink);line-height:1.5;">years working with families in systemic therapy</p>
            </div>
            <ul style="margin:6px 0 0;padding-left:18px;display:flex;flex-direction:column;gap:5px;list-style:disc;">
              <li style="font-size:14px;color:#6a6460;line-height:1.5;">Lead instructor at Instituto Corpore since 2026</li>
              <li style="font-size:14px;color:#6a6460;line-height:1.5;">Group facilitator since 2018</li>
              <li style="font-size:14px;color:#6a6460;line-height:1.5;">5 editions of the "Menos es más" workshop</li>
            </ul>
            <div style="margin-top:16px;padding-top:14px;border-top:1px solid var(--cream);">
              <p style="margin:0 0 8px;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--sand-d);">Teaching assistant in the training programs of</p>
              <ul style="margin:0;padding-left:18px;display:flex;flex-direction:column;gap:5px;list-style:disc;">
                <li style="font-size:14px;color:#6a6460;line-height:1.5;">Instituto Corpore 12th Cohort</li>
                <li style="font-size:14px;color:#6a6460;line-height:1.5;">Experiencia Somática México 5th Cohort</li>
                <li style="font-size:14px;color:#6a6460;line-height:1.5;">Experiencia Somática Uruguay 14th Cohort</li>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="position:relative;overflow:hidden;background:var(--purple);padding:clamp(64px,9vw,112px) 32px;text-align:center;">
    <div style="position:absolute;bottom:-80px;right:-120px;width:400px;height:400px;opacity:.14;pointer-events:none;background:repeating-conic-gradient(#fff 0deg .55deg,transparent .55deg 7deg);-webkit-mask:radial-gradient(circle,transparent 29%,#000 30%,#000 49%,transparent 50%);mask:radial-gradient(circle,transparent 29%,#000 30%,#000 49%,transparent 50%);"></div>
    <div data-reveal style="position:relative;max-width:700px;margin:0 auto;">
      <h2 style="font-family:'Zilla Slab',serif;font-weight:600;color:#fff;font-size:clamp(28px,4vw,50px);line-height:1.08;margin:0 0 20px;text-wrap:balance;">Do you want to take the first step?</h2>
      <p style="font-size:clamp(15px,1.1vw,18px);line-height:1.65;color:rgba(255,255,255,.82);margin:0 auto 32px;max-width:50ch;">Every process begins with a conversation. Reach out and let's see, with no commitment, if this accompaniment is right for you.</p>
      <a href="https://wa.me/patriciomx" target="_blank" rel="noopener" class="btn-white">Book your first session</a>
    </div>
  </section>

</Base>
