---
import Base from '../../layouts/Base.astro';
import TestimonialCarousel from '../../components/TestimonialCarousel.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import Img from '../../components/Img.astro';
import { t } from '../../i18n/utils';
import { businessSchema, personSchema } from '../../data/person';

const locale = 'en';
const i = t(locale);

const schema = businessSchema(locale, i.site.description);
const authorSchema = personSchema(locale);
---

<Base title={i.site.title} description={i.site.description} altPath="/" ogImage="/uploads/og/home-en.webp" schema={schema} extraSchemas={[authorSchema]}>

  <!-- HERO -->
  <SiteHeader
    eyebrow={i.hero.label}
    title={i.hero.title}
    meta={i.hero.meta}
    photo="/uploads/patricio-ruiz-retrato.webp"
    photoAlt="Portrait of Patricio Ruiz Abrín, psychotherapist, a young adult with medium complexion and dark hair, with a calm expression and warm gaze"
    photoPosition="center bottom"
    ctaLabel={i.hero.cta}
    ctaHref="https://wa.me/patriciomx"
    secondaryLabel={i.hero.secondary}
    secondaryHref="#modalities"
    stats={i.hero.stats}
  >
    <p>{i.hero.subtitle}</p>
  </SiteHeader>

  <!-- APPROACH -->
  <section class="section">
    <div class="container--narrow" style="text-align:center;">
      <p data-reveal class="label-section">{i.approach.label}</p>
      <h2 data-reveal style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:clamp(28px,4.2vw,48px);line-height:1.1;letter-spacing:-.01em;margin:0 auto 32px;max-width:18ch;text-wrap:balance;">{i.approach.title}</h2>
      <p data-reveal class="body-text" style="margin:0 auto 22px;max-width:68ch;">{i.approach.p1}</p>
      <p data-reveal class="body-text" style="margin:0 auto 34px;max-width:68ch;">{i.approach.p2}</p>
      <a data-reveal href="/en/blog/types-of-therapy/" class="link-underline">{i.approach.link}</a>
    </div>
  </section>

  <!-- MODALITIES -->
  <section id="modalities" class="section section--cream">
    <div class="container">
      <div style="text-align:center;margin-bottom:clamp(40px,5vw,64px);">
        <p data-reveal class="label-section">{i.modalities.label}</p>
        <h2 data-reveal class="heading-section">{i.modalities.title}</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:26px;" class="modal-grid">

        <div data-reveal class="card" style="padding:38px 32px;display:flex;flex-direction:column;gap:18px;">
          <div style="width:112px;height:112px;border-radius:50%;background:linear-gradient(160deg,var(--cream-2),var(--cream));display:flex;align-items:center;justify-content:center;">
            <Img src="/uploads/icono-terapia-individual.webp" alt="" sizes="96px" style="height:78px;width:auto;display:block;" />
          </div>
          <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--wine);font-size:26px;margin:0;">{i.modalities.individual.title}</h3>
          <p style="font-size:16px;line-height:1.65;color:#4a443f;margin:0;flex:1;">{i.modalities.individual.desc}</p>
          <a href="/en/therapy/individual/" style="color:var(--purple);font-weight:700;font-size:14px;letter-spacing:.04em;text-decoration:none;align-self:flex-start;">{i.modalities.individual.link}</a>
        </div>

        <div data-reveal class="card" style="padding:38px 32px;display:flex;flex-direction:column;gap:18px;">
          <div style="width:112px;height:112px;border-radius:50%;background:linear-gradient(160deg,var(--cream-2),var(--cream));display:flex;align-items:center;justify-content:center;">
            <Img src="/uploads/icono-terapia-pareja.webp" alt="" sizes="96px" style="height:96px;width:auto;display:block;" />
          </div>
          <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--wine);font-size:26px;margin:0;">{i.modalities.couples.title}</h3>
          <p style="font-size:16px;line-height:1.65;color:#4a443f;margin:0;flex:1;">{i.modalities.couples.desc}</p>
          <a href="/en/therapy/couples/" style="color:var(--purple);font-weight:700;font-size:14px;letter-spacing:.04em;text-decoration:none;align-self:flex-start;">{i.modalities.couples.link}</a>
        </div>

        <div data-reveal class="card" style="padding:38px 32px;display:flex;flex-direction:column;gap:18px;">
          <div style="width:112px;height:112px;border-radius:50%;background:linear-gradient(160deg,var(--cream-2),var(--cream));display:flex;align-items:center;justify-content:center;">
            <Img src="/uploads/icono-terapia-familiar.webp" alt="" sizes="96px" style="height:88px;width:auto;display:block;" />
          </div>
          <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--wine);font-size:26px;margin:0;">{i.modalities.family.title}</h3>
          <p style="font-size:16px;line-height:1.65;color:#4a443f;margin:0;flex:1;">{i.modalities.family.desc}</p>
          <a href="/en/therapy/family/" style="color:var(--purple);font-weight:700;font-size:14px;letter-spacing:.04em;text-decoration:none;align-self:flex-start;">{i.modalities.family.link}</a>
        </div>

      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <TestimonialCarousel locale={locale} />

  <!-- PODCAST -->
  <section style="background:linear-gradient(135deg,var(--purple) 0%,var(--purple-d) 100%);padding:clamp(56px,8vw,100px) 32px;overflow:hidden;position:relative;">
    <div style="position:absolute;top:-60px;right:-60px;width:320px;height:320px;border-radius:50%;background:rgba(194,176,126,.07);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-80px;left:-40px;width:260px;height:260px;border-radius:50%;background:rgba(194,176,126,.05);pointer-events:none;"></div>
    <div style="position:relative;max-width:820px;margin:0 auto;display:flex;gap:clamp(32px,5vw,64px);align-items:center;flex-wrap:wrap;">
      <div style="flex:1 1 320px;">
        <p data-reveal style="margin:0 0 14px;font-weight:700;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--sand);">{i.podcast.label}</p>
        <h2 data-reveal style="font-family:'Zilla Slab',serif;font-weight:600;color:#fff;font-size:clamp(26px,3.8vw,42px);line-height:1.1;margin:0 0 16px;text-wrap:balance;">{i.podcast.title}</h2>
        <p data-reveal style="font-size:clamp(15px,1.1vw,17px);line-height:1.65;color:rgba(255,255,255,.82);margin:0;">{i.podcast.desc}</p>
      </div>
      <div data-reveal style="flex:1 1 280px;">
        <form id="podcast-form" action="https://formspree.io/f/mzdqnrka" method="POST" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);border-radius:18px;padding:28px 26px;display:flex;flex-direction:column;gap:14px;">
          <input type="hidden" name="_subject" value="Podcast request — inessentia.mx">
          <label style="font-size:13px;color:rgba(255,255,255,.7);font-weight:600;letter-spacing:.04em;">{i.podcast.nameLabel}</label>
          <input type="text" name="nombre" placeholder={i.podcast.namePlaceholder} required style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:9px;padding:12px 14px;font-size:15px;color:#fff;font-family:'Mulish',sans-serif;outline:none;">
          <label style="font-size:13px;color:rgba(255,255,255,.7);font-weight:600;letter-spacing:.04em;">{i.podcast.emailLabel}</label>
          <input type="email" name="email" placeholder={i.podcast.emailPlaceholder} required style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:9px;padding:12px 14px;font-size:15px;color:#fff;font-family:'Mulish',sans-serif;outline:none;">
          <button type="submit" style="background:var(--sand);color:var(--purple-d);font-weight:700;font-size:14px;letter-spacing:.06em;text-transform:uppercase;padding:14px 24px;border:none;border-radius:999px;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:'Mulish',sans-serif;">{i.podcast.submit}</button>
          <p style="margin:0;font-size:12px;color:rgba(255,255,255,.4);text-align:center;line-height:1.5;">{i.podcast.privacy} <a href="/en/privacy/" style="color:rgba(255,255,255,.6);font-weight:700;text-decoration:none;">{i.podcast.privacyLink}</a>.</p>
        </form>
        <div id="podcast-thanks" style="display:none;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);border-radius:18px;padding:28px 26px;text-align:center;">
          <p style="font-size:32px;margin:0 0 12px;">{i.podcast.thanksEmoji}</p>
          <p style="font-family:'Zilla Slab',serif;font-size:22px;color:#fff;font-weight:600;margin:0 0 10px;">{i.podcast.thanksTitle}</p>
          <a href="https://speechify.app.link/gnd5mf9tn4b" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:8px;background:var(--sand);color:var(--purple-d);font-weight:700;font-size:14px;padding:13px 26px;border-radius:999px;text-decoration:none;margin-top:6px;">{i.podcast.thanksCta}</a>
          <p style="font-size:13px;color:rgba(255,255,255,.5);margin:14px 0 0;">{i.podcast.thanksNote}</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
  (function() {
    var form = document.getElementById('podcast-form');
    if (!form) return;
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }
      var btn = form.querySelector('button[type="submit"]');
      if (btn) { btn.disabled = true; btn.textContent = 'Sending...'; }
      fetch('https://formspree.io/f/mzdqnrka', {
        method: 'POST', body: new FormData(form), headers: { 'Accept': 'application/json' }
      }).then(function(r) {
        if (!r.ok) throw new Error();
        form.style.display = 'none';
        var thanks = document.getElementById('podcast-thanks');
        if (thanks) thanks.style.display = 'block';
      }).catch(function() {
        if (btn) { btn.disabled = false; btn.textContent = 'Get the podcast'; }
      });
    });
  })();
  </script>

  <!-- BLOG -->
  <section class="section section--cream">
    <div class="container">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;gap:24px;flex-wrap:wrap;margin-bottom:clamp(36px,4vw,56px);">
        <div data-reveal>
          <p class="label-section">{i.blog.label}</p>
          <h2 class="heading-section">{i.blog.title}</h2>
        </div>
        <a data-reveal href="/en/resources/" class="link-underline">{i.blog.seeAll}</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:26px;" class="blog-grid">

        <a data-reveal href="/en/blog/what-to-expect/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="position:relative;height:184px;overflow:hidden;"><Img src="/uploads/que-esperar-terapia.webp" sizes="(max-width:640px) 100vw, 380px" alt="Portrait of a young woman with a warm gaze holding a heart-shaped object and showing it to the camera" style="width:100%;height:100%;object-fit:cover;object-position:center 20%;display:block;" /></div>
          <div style="padding:28px 28px 30px;display:flex;flex-direction:column;gap:12px;flex:1;">
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:22px;line-height:1.2;margin:0;">What to expect from therapy?</h3>
            <p style="font-size:15px;line-height:1.6;color:#4a443f;margin:0;flex:1;">How the therapeutic relationship, techniques and time come together in a real process.</p>
            <span style="color:var(--wine);font-weight:700;font-size:14px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/first-session/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="position:relative;height:184px;overflow:hidden;"><Img src="/uploads/primera-cita-terapia.webp" sizes="(max-width:640px) 100vw, 380px" alt="Empty therapy room with two armchairs facing each other, warm afternoon light" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;" /></div>
          <div style="padding:28px 28px 30px;display:flex;flex-direction:column;gap:12px;flex:1;">
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:22px;line-height:1.2;margin:0;">What's a first session usually like?</h3>
            <p style="font-size:15px;line-height:1.6;color:#4a443f;margin:0;flex:1;">When you reach out for the first time, here's how we get started.</p>
            <span style="color:var(--wine);font-weight:700;font-size:14px;">{i.blog.readMore}</span>
          </div>
        </a>

        <a data-reveal href="/en/blog/good-time-to-start/" class="card" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
          <div style="position:relative;height:184px;overflow:hidden;"><Img src="/uploads/buen-momento-pareja.webp" sizes="(max-width:640px) 100vw, 380px" alt="Person sitting by a window in morning light, holding a cup, contemplative mood" style="width:100%;height:100%;object-fit:cover;object-position:center 55%;display:block;" /></div>
          <div style="padding:28px 28px 30px;display:flex;flex-direction:column;gap:12px;flex:1;">
            <h3 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:22px;line-height:1.2;margin:0;">When is a good time to start therapy?</h3>
            <p style="font-size:15px;line-height:1.6;color:#4a443f;margin:0;flex:1;">The signs worth listening to — and why asking for help doesn't require hitting rock bottom.</p>
            <span style="color:var(--wine);font-weight:700;font-size:14px;">{i.blog.readMore}</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="position:relative;overflow:hidden;background:var(--purple);padding:clamp(64px,9vw,118px) 32px;text-align:center;">
    <div style="position:absolute;top:50%;left:-140px;transform:translateY(-50%);width:460px;height:460px;opacity:.16;pointer-events:none;background:repeating-conic-gradient(#fff 0deg .55deg,transparent .55deg 7deg);-webkit-mask:radial-gradient(circle,transparent 29%,#000 30%,#000 49%,transparent 50%);mask:radial-gradient(circle,transparent 29%,#000 30%,#000 49%,transparent 50%);"></div>
    <div data-reveal style="position:relative;max-width:760px;margin:0 auto;">
      <h2 style="font-family:'Zilla Slab',serif;font-weight:600;color:#fff;font-size:clamp(30px,4.6vw,54px);line-height:1.08;margin:0 0 22px;text-wrap:balance;">{i.cta.title}</h2>
      <p style="font-size:clamp(16px,1.2vw,19px);line-height:1.65;color:rgba(255,255,255,.82);margin:0 auto 36px;max-width:52ch;">{i.cta.desc}</p>
      <a href="https://wa.me/patriciomx" target="_blank" rel="noopener" class="btn-white">{i.cta.button}</a>
    </div>
  </section>

</Base>
