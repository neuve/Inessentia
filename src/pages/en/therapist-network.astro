      {"nombre":"Itzel Alejandra González Sánchez","tipo":"Psicoterapia","subtipo":"Terapia somática","enfoques":["Humanismo (Enfoque Centrado a la Persona)","Core energética","Gestalt","Psicoterapia existencial"],"especialidades":"Estrés, ansiedad y depresión. Identidad y diversidad sexual y de género. Trauma. Relaciones sexoafectivas.","telefono":"4776778213","webpage":"https://www.doctoralia.com.mx/z/inaHGg / https://www.psychologytoday.com/profile/1455113","casos":["Individual"],"modalidades":["Online","Presencial"],"zona":"Lomas del Campestre, León, Guanajuato","cp":"37150","idiomas":[],"costo":600,"disponibilidad":"Agenda abierta","lat":21.1230,"lng":-101.6640},
      {"nombre":"Claudia Stepensky","tipo":"Psicoterapia","subtipo":"Terapia somática","enfoques":["Terapia familiar sistémica","Experiencia somática","Core energética"],"especialidades":"Ansiedad, depresión, dificultades relacionales, trauma, duelos, crisis. +20 años de experiencia.","telefono":"9988743971","webpage":null,"casos":["Individual","Pareja","Familia"],"modalidades":["Online","Presencial"],"zona":"Valle de Bravo, Estado de México","cp":"51200","idiomas":["Inglés"],"costo":1800,"disponibilidad":"Agenda abierta","lat":19.1927,"lng":-100.1316},
      {"nombre":"Hilda Martinez Vega","tipo":"Psicoterapia","subtipo":"Terapia somática","enfoques":["Experiencia somática","Osteopatía visceral y neural","Terapia Craneosacral","Medicina Germánica"],"especialidades":"Abuso sexual, accidentes, ansiedad, dolor crónico, enfermedades autoinmunes, fatiga crónica, migrañas, insomnio.","telefono":"5511957245","webpage":null,"casos":["Individual"],"modalidades":["Online","Presencial"],"zona":"Tequisquiapan, Querétaro","cp":"76790","idiomas":[],"costo":1000,"disponibilidad":"Agenda abierta","lat":20.5222,"lng":-99.8935}
    ];

    // ── COLOR CONFIG ────────────────────────────────────────────────────────
    var TIPO_ORDER = ['Psicoterapia','Terapia Física','Psiquiátrica'];
    var TIPO_COLOR = {'Psicoterapia':'#3A6858','Terapia Física':'#B97050','Psiquiátrica':'#3D5A8A'};
    var SUBTIPO_COLOR = {'Terapia somática':'#3A6858','Terapia transpersonal':'#7A6BA0','Terapia psicológica':'#5B8BA0'};
    var SUBTIPO_TAG = {'Terapia somática':'tag-somatica','Terapia transpersonal':'tag-transpersonal','Terapia psicológica':'tag-psicologica'};
    var TIPO_TAG = {'Terapia Física':'tag-fisica','Psiquiátrica':'tag-psiquiatrica'};

    var getColor = function(t) { return (t.subtipo && SUBTIPO_COLOR[t.subtipo]) || TIPO_COLOR[t.tipo] || '#8B8378'; };
    var getTagClass = function(t) { return (t.subtipo && SUBTIPO_TAG[t.subtipo]) || TIPO_TAG[t.tipo] || 'tag-somatica'; };
    var getTagLabel = function(t) { return t.subtipo || t.tipo; };

    // ── MAP INIT ─────────────────────────────────────────────────────────────
    var mapEl = document.getElementById('ri-map');
    if (!mapEl) return;
    var map = L.map('ri-map', { center: [19.39, -99.17], zoom: 11 });
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap contributors &copy; CARTO', maxZoom: 19
    }).addTo(map);

    // ── SCATTER ──────────────────────────────────────────────────────────────
    var grupos = {};
    TERAPEUTAS.forEach(function(t) {
      if (t.lat == null) return;
      var k = t.lat.toFixed(3) + ',' + t.lng.toFixed(3);
      (grupos[k] = grupos[k] || []).push(t);
    });
    Object.values(grupos).forEach(function(g) {
      if (g.length < 2) return;
      var r = 0.002;
      g.forEach(function(t, i) { var a = (2*Math.PI*i)/g.length; t.lat += r*Math.cos(a); t.lng += r*Math.sin(a); });
    });

    // ── HELPERS ──────────────────────────────────────────────────────────────
    function parseWebLinks(raw) {
      if (!raw || !raw.trim()) return [];
      var links = [];
      var text = raw.replace(/\bIG[:\s]+/gi, '@').replace(/\bInstagram[:\s.]+/gi, '@');
      var igUrlRe = /https?:\/\/(?:www\.)?instagram\.com\/([^/?#\s]+)/gi;
      var m;
      while ((m = igUrlRe.exec(text)) !== null) {
        var u = m[1].replace(/\/$/, '');
        if (u) links.push({ type:'ig', url:m[0], label:'@'+u });
      }
      text = text.replace(/https?:\/\/(?:www\.)?instagram\.com\/[^\s,]*/gi, '');
      var handleRe = /@([\w.]+)/g;
      while ((m = handleRe.exec(text)) !== null) {
        var u = m[1].replace(/\.+$/, '');
        if (u) links.push({ type:'ig', url:'https://instagram.com/'+u, label:'@'+u });
      }
      text = text.replace(/@[\w.]+/g, '');
      // YouTube
      var ytRe = /https?:\/\/(?:www\.)?youtube\.com\/[^\s,]+/g;
      while ((m = ytRe.exec(text)) !== null) {
        links.push({ type:'yt', url:m[0].replace(/[.,;)]+$/,''), label:'YouTube' });
      }
      text = text.replace(/https?:\/\/(?:www\.)?youtube\.com\/[^\s,]*/g, '');
      var urlRe = /https?:\/\/[^\s,]+|www\.[^\s,]+/g;
      while ((m = urlRe.exec(text)) !== null) {
        var url = m[0].replace(/[.,;)]+$/, '');
        if (!url.startsWith('http')) url = 'https://'+url;
        links.push({ type:'web', url:url, label:'Website' });
      }
      return links;
    }

    function crearIcono(t) {
      var color = getColor(t);
      var svg = '<svg xmlns="http://www.w3.org/2000/svg" width="30" height="38" viewBox="0 0 30 38"><path d="M15 0C6.716 0 0 6.716 0 15c0 9.375 15 23 15 23S30 24.375 30 15C30 6.716 23.284 0 15 0z" fill="'+color+'" opacity="0.9"/><circle cx="15" cy="15" r="7" fill="white" opacity="0.9"/><circle cx="15" cy="15" r="3.5" fill="'+color+'"/></svg>';
      return L.divIcon({ html:svg, className:'', iconSize:[30,38], iconAnchor:[15,38], popupAnchor:[0,-42] });
    }

    function modTag(m) {
      var cls = m==='Online'?'tag-online':m==='Presencial'?'tag-presencial':'tag-domicilio';
      return '<span class="tag '+cls+'">'+m+'</span>';
    }

    function crearPopup(t) {
      var color = getColor(t);
      var tipoLabel = t.subtipo ? t.tipo+' · '+t.subtipo : t.tipo;
      var modTags = (t.modalidades||[]).map(modTag).join('');
      var idiomaTag = t.idiomas && t.idiomas.length ? '<span class="tag tag-idioma">🌐 '+t.idiomas.join(', ')+'</span>' : '';
      var listaTag = t.disponibilidad && t.disponibilidad !== 'Agenda abierta' ? '<span class="tag tag-lista">⏳ Waitlist</span>' : '';
      var webLinks = parseWebLinks(t.webpage);
      var webHtml = webLinks.map(function(l) {
        var icon = l.type==='ig'?'📸':l.type==='yt'?'▶️':'🌐';
        return '<a href="'+l.url+'" target="_blank" class="popup-link" style="color:'+color+'">'+icon+' '+l.label+' ↗</a>';
      }).join('');
      var ubicacion = t.zona && t.zona.toLowerCase()!=='solo online'
        ? '📍 '+t.zona+(t.cp?' · CP '+t.cp:'') : '🌐 Online only';
      return '<div class="popup-header" style="border-top-color:'+color+'">'+
        '<div class="popup-tipo">'+tipoLabel+'</div>'+
        '<div class="popup-name">'+t.nombre+'</div>'+
        '<div class="popup-city">'+ubicacion+'</div>'+
      '</div>'+
      '<div class="popup-body">'+
        '<div class="popup-section"><div class="popup-section-label">Approaches</div><div class="popup-section-value">'+(t.enfoques||[]).join(' · ')+'</div></div>'+
        (t.especialidades?'<div class="popup-section"><div class="popup-section-label">Specialties</div><div class="popup-section-value" style="font-size:.76rem;color:#555">'+t.especialidades+'</div></div>':'')+
        '<div class="popup-section"><div class="popup-section-label">Works with</div><div class="popup-section-value">'+(t.casos||[]).join(', ')+'</div></div>'+
        '<div class="popup-tags">'+modTags+idiomaTag+listaTag+'</div>'+
      '</div>'+
      '<div class="popup-footer">'+
        (t.telefono?'<a href="tel:'+t.telefono+'" class="popup-link" style="color:'+color+'">📞 '+t.telefono+'</a>':'')+
        webHtml+
        (t.costo?'<span class="popup-costo">$'+t.costo.toLocaleString()+' · 1st session</span>':'')+
      '</div>';
    }

    // ── STATE ────────────────────────────────────────────────────────────────
    var markers = [];
    var modalidadActiva = '';
    var activeCasos = new Set();

    // ── FILTER FUNCTIONS ────────────────────────────────────────────────────
    window.riSetModalidad = function(val) {
      modalidadActiva = val;
      document.querySelectorAll('.ri-mod-btn').forEach(function(b) { b.classList.remove('active'); });
      var id = val===''?'ri-mod-all':val==='Online'?'ri-mod-online':'ri-mod-presencial';
      var btn = document.getElementById(id); if (btn) btn.classList.add('active');
      riApplyFilters();
    };
    window.riToggleCaso = function(caso, el) {
      activeCasos.has(caso) ? activeCasos.delete(caso) : activeCasos.add(caso);
      if (el) el.classList.toggle('active');
      riApplyFilters();
    };
    window.riOnTipoChange = function() {
      var tipo = document.getElementById('filterTipo').value;
      var subSel = document.getElementById('filterSubtipo');
      if (subSel) subSel.style.display = tipo==='Psicoterapia'?'inline-block':'none';
      riPoblarEnfoques(tipo, '');
      riApplyFilters();
    };
    window.riOnSubtipoChange = function() {
      var tipo = document.getElementById('filterTipo').value;
      var subtipo = document.getElementById('filterSubtipo').value;
      riPoblarEnfoques(tipo, subtipo);
      var ef = document.getElementById('filterEnfoque'); if (ef) ef.value='';
      riApplyFilters();
    };
    window.riApplyFilters = function() {
      var tipo    = (document.getElementById('filterTipo')||{}).value||'';
      var subtipo = (document.getElementById('filterSubtipo')||{}).value||'';
      var enfoque = (document.getElementById('filterEnfoque')||{}).value||'';
      var zona    = ((document.getElementById('filterZona')||{}).value||'').toLowerCase().trim();
      markers.forEach(function(m) { map.removeLayer(m); });
      markers = [];
      var lc = document.getElementById('list-container');
      if (lc) lc.innerHTML = '';
      var visible = 0;
      TERAPEUTAS.forEach(function(t) {
        if (!t.lat || !t.lng) return;
        if (tipo    && t.tipo    !== tipo)    return;
        if (subtipo && t.subtipo !== subtipo) return;
        if (enfoque && !(t.enfoques||[]).includes(enfoque)) return;
        if (modalidadActiva && !(t.modalidades||[]).includes(modalidadActiva)) return;
        if (activeCasos.size > 0 && ![...activeCasos].some(function(c) { return (t.casos||[]).includes(c); })) return;
        if (zona && !(t.zona||'').toLowerCase().includes(zona) && !(t.cp||'').includes(zona)) return;
        var idx = markers.length;
        var marker = L.marker([t.lat,t.lng],{icon:crearIcono(t)}).bindPopup(crearPopup(t),{maxWidth:310}).addTo(map);
        marker.on('click', function() { activarItem(idx); });
        markers.push(marker);
        agregarALista(t, idx);
        visible++;
      });
      if (visible===0 && TERAPEUTAS.length>0 && lc)
        lc.innerHTML = '<div class="ri-no-results">No results for these filters.<br>Try fewer criteria.</div>';
      var ctr = document.getElementById('ri-counter');
      if (ctr) ctr.textContent = visible + ' therapist' + (visible!==1?'s':'');
    };

    function activarItem(idx) {
      document.querySelectorAll('.therapist-item').forEach(function(el) { el.classList.remove('active'); });
      var item = document.querySelector('[data-idx="'+idx+'"]');
      if (item) {
        item.classList.add('active');
        var container = item.closest('.ri-list-container');
        if (container) {
          var top = item.offsetTop - container.offsetTop;
          container.scrollTop = top - container.clientHeight / 2 + item.clientHeight / 2;
        }
      }
    }

    function agregarALista(t, idx) {
      var modTags = (t.modalidades||[]).map(modTag).join('');
      var idiomTag = t.idiomas && t.idiomas.length ? '<span class="tag tag-idioma">🌐 '+t.idiomas.join(', ')+'</span>' : '';
      var listaTag = t.disponibilidad && t.disponibilidad!=='Agenda abierta' ? '<span class="tag tag-lista">⏳ Waitlist</span>' : '';
      var el = document.createElement('div');
      el.className = 'therapist-item';
      el.setAttribute('data-idx', idx);
      el.innerHTML = '<div class="therapist-name">'+t.nombre+'</div><div class="therapist-location">📍 '+t.zona+'</div><div class="therapist-tags"><span class="tag '+getTagClass(t)+'">'+getTagLabel(t)+'</span>'+modTags+idiomTag+listaTag+'</div>';
      el.onclick = function() {
        activarItem(idx);
        if (markers[idx]) { map.setView(markers[idx].getLatLng(), 14, {animate:true}); markers[idx].openPopup(); }
      };
      var lc = document.getElementById('list-container');
      if (lc) lc.appendChild(el);
    }

    function riPoblarEnfoques(tipoF, subtipoF) {
      var enfoques = new Set();
      TERAPEUTAS.forEach(function(t) {
        if (tipoF && t.tipo!==tipoF) return;
        if (subtipoF && t.subtipo!==subtipoF) return;
        (t.enfoques||[]).forEach(function(e) { enfoques.add(e); });
      });
      var prev = (document.getElementById('filterEnfoque')||{}).value||'';
      var sel = document.getElementById('filterEnfoque');
      if (!sel) return;
      sel.innerHTML = '<option value="">All approaches</option>';
      [...enfoques].sort().forEach(function(e) {
        var opt = document.createElement('option');
        opt.value = e; opt.textContent = e;
        if (e===prev) opt.selected = true;
        sel.appendChild(opt);
      });
    }

    // ── BIND EVENT LISTENERS ────────────────────────────────────────────────
    var _fTipo = document.getElementById('filterTipo');
    var _fSubtipo = document.getElementById('filterSubtipo');
    var _fEnfoque = document.getElementById('filterEnfoque');
    var _fZona = document.getElementById('filterZona');
    if (_fTipo) _fTipo.addEventListener('change', function() { riOnTipoChange(); });
    if (_fSubtipo) _fSubtipo.addEventListener('change', function() { riOnSubtipoChange(); });
    if (_fEnfoque) _fEnfoque.addEventListener('change', function() { riApplyFilters(); });
    if (_fZona) _fZona.addEventListener('input', function() { riApplyFilters(); });
    document.querySelectorAll('[data-mod]').forEach(function(btn) {
      btn.addEventListener('click', function() { riSetModalidad(btn.getAttribute('data-mod')); });
    });
    document.querySelectorAll('[data-caso]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var caso = btn.getAttribute('data-caso');
        activeCasos.has(caso) ? activeCasos.delete(caso) : activeCasos.add(caso);
        btn.classList.toggle('active');
        riApplyFilters();
      });
    });

    // ── POPULATE SELECTS ─────────────────────────────────────────────────────
    var tipos = [...new Set(TERAPEUTAS.map(function(t){ return t.tipo; }).filter(Boolean))];
    tipos.sort(function(a,b) { var ia=TIPO_ORDER.indexOf(a),ib=TIPO_ORDER.indexOf(b); return (ia===-1?99:ia)-(ib===-1?99:ib); });
    var tipoSel = document.getElementById('filterTipo');
    if (tipoSel) tipos.forEach(function(tipo) { var o=document.createElement('option'); o.value=tipo; o.textContent=tipo; tipoSel.appendChild(o); });

    var subtipos = [...new Set(TERAPEUTAS.filter(function(t){ return t.tipo==='Psicoterapia'&&t.subtipo; }).map(function(t){ return t.subtipo; }))].sort();
    var subSel = document.getElementById('filterSubtipo');
    if (subSel) { subSel.innerHTML='<option value="">All types</option>'; subtipos.forEach(function(s) { var o=document.createElement('option'); o.value=s; o.textContent=s; subSel.appendChild(o); }); }

    riPoblarEnfoques('','');

    // ── DONE ─────────────────────────────────────────────────────────────────
    var loading = document.getElementById('ri-loading');
    var lbar = document.getElementById('ri-loading-bar');
    var lmsg = document.getElementById('ri-loading-msg');
    if (lbar) lbar.style.width = '100%';
    if (lmsg) lmsg.textContent = '20 therapists loaded';
    setTimeout(function() { if (loading) loading.style.display='none'; riApplyFilters(); }, 600);

    // Invalidate map size after layout settles
    setTimeout(function() { map.invalidateSize(); }, 200);
  }
})();
</script>

