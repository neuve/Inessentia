---
import Base from './Base.astro';
import DisqusComments from '../components/DisqusComments.astro';
import { t, sitePath, type Locale } from '../i18n/utils';

interface VideoSchema {
  name: string;
  description: string;
  thumbnailUrl: string;
  contentUrl: string;
  embedUrl: string;
  uploadDate?: string;
}

interface Props {
  locale: Locale;
  title: string;
  description: string;
  altPath: string;
  category: string;
  heroImage: string;
  heroAlt: string;
  heroPosition?: string;
  heroCaption?: string;
  heroParallax?: boolean;
  disqusIdentifier: string;
  nextPost?: { href: string; label: string };
  videos?: VideoSchema[];
}

const {
  locale,
  title,
  description,
  altPath,
  category,
  heroImage,
  heroAlt,
  heroPosition = 'center 20%',
  heroCaption,
  heroParallax = false,
  disqusIdentifier,
  nextPost,
  videos,
} = Astro.props;

const heroImgStyle = heroParallax
  ? `position:absolute;top:50%;left:0;width:100%;height:130%;object-fit:cover;object-position:${heroPosition};display:block;transform:translate3d(0,calc(-50% + var(--parallax-y, 0px)),0);will-change:transform;`
  : `width:100%;height:100%;object-fit:cover;object-position:${heroPosition};display:block;`;

const i = t(locale);
const resourcesPath = sitePath(locale, 'resources');
const resourcesLabel = locale === 'es' ? '← Recursos' : '← Resources';
const ctaTitle = locale === 'es' ? '¿Listo para empezar?' : 'Ready to start?';
const ctaButton = locale === 'es' ? 'Agenda tu primera cita' : 'Book Your First Session';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "image": `https://inessentia.mx${heroImage}`,
  "inLanguage": locale,
  "author": {
    "@type": "Person",
    "name": "Patricio Ruiz Abrín",
    "url": `https://inessentia.mx/${locale}/${locale === 'es' ? 'sobre-mi' : 'about-me'}/`
  },
  "publisher": {
    "@type": "Organization",
    "name": "Inessentia",
    "logo": { "@type": "ImageObject", "url": "https://inessentia.mx/uploads/logo-patricio-ruiz.webp" }
  },
  "mainEntityOfPage": `https://inessentia.mx${Astro.url.pathname}`
};
---

<Base title={`${title} | Blog Inessentia`} description={description} altPath={altPath} schema={schema} extraSchemas={videos?.map(v => ({
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": v.name,
  "description": v.description,
  "thumbnailUrl": v.thumbnailUrl,
  "uploadDate": v.uploadDate ?? "2024-01-01T00:00:00-06:00",
  "contentUrl": v.contentUrl,
  "embedUrl": v.embedUrl,
}))}>


  <!-- HERO -->
  <section style="background:linear-gradient(180deg,var(--cream) 0%,var(--warm) 100%);padding:clamp(56px,8vw,96px) 32px clamp(40px,5vw,64px);">
    <div style="max-width:760px;margin:0 auto;">
      <a href={resourcesPath} style="display:inline-flex;align-items:center;gap:6px;color:var(--wine);font-weight:700;font-size:13px;text-decoration:none;letter-spacing:.06em;text-transform:uppercase;margin-bottom:28px;">{resourcesLabel}</a>
      <p style="margin:0 0 16px;font-weight:700;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--wine);">{category}</p>
      <h1 style="font-family:'Zilla Slab',serif;font-weight:600;color:var(--purple);font-size:clamp(32px,4.5vw,52px);line-height:1.06;margin:0 0 22px;text-wrap:balance;">{title}</h1>
      <p style="font-size:clamp(16px,1.2vw,19px);line-height:1.65;color:#4a443f;margin:0;max-width:54ch;">{description}</p>
    </div>
  </section>

  <!-- HERO IMAGE -->
  <div style="position:relative;width:100%;height:clamp(240px,38vw,460px);overflow:hidden;">
    <img src={heroImage} width="1200" height="800" loading="lazy" alt={heroAlt} data-parallax={heroParallax || undefined} style={heroImgStyle}>
  </div>
  {heroCaption && (
    <p style="max-width:680px;margin:8px auto 0;padding:0 32px;font-size:13px;color:var(--sand-d);text-align:center;">{heroCaption}</p>
  )}

  <script>
    import { initHeroParallax } from '../scripts/hero-parallax.js';
    initHeroParallax();
  </script>

  <!-- CONTENT -->
  <section style="padding:clamp(40px,6vw,72px) 32px clamp(64px,9vw,120px);">
    <div style="max-width:680px;margin:0 auto;display:flex;flex-direction:column;gap:22px;" class="blog-content">
      <slot />

      {nextPost && (
        <div style="padding-top:16px;border-top:1px solid var(--cream);display:flex;gap:16px;flex-wrap:wrap;">
          <a href={nextPost.href} class="link-underline">{nextPost.label}</a>
        </div>
      )}
    </div>
  </section>

  <!-- COMMENTS -->
  <section style="padding:clamp(48px,6vw,80px) 32px;background:var(--cream-2);">
    <div style="max-width:760px;margin:0 auto;">
      <DisqusComments
        identifier={disqusIdentifier}
        url={`https://inessentia.mx${disqusIdentifier}`}
        language={locale}
      />
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--purple);padding:clamp(56px,8vw,96px) 32px;text-align:center;">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-family:'Zilla Slab',serif;font-weight:600;color:#fff;font-size:clamp(26px,3.5vw,42px);line-height:1.1;margin:0 0 20px;text-wrap:balance;">{ctaTitle}</h2>
      <a href="https://wa.me/patriciomx" target="_blank" rel="noopener" class="btn-white">{ctaButton}</a>
    </div>
  </section>

</Base>
