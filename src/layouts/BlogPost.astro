---
import Base from './Base.astro';
import Img from '../components/Img.astro';
import DisqusComments from '../components/DisqusComments.astro';
import { t, sitePath, type Locale } from '../i18n/utils';
import { personSchema, personRef, PERSON_ALT_NAME } from '../data/person';

interface VideoSchema {
  name: string;
  description: string;
  thumbnailUrl: string;
  contentUrl: string;
  embedUrl: string;
  uploadDate?: string;
}

interface Props {
  locale: Locale;
  title: string;
  description: string;
  altPath: string;
  category: string;
  heroImage: string;
  ogImage: string;
  heroAlt: string;
  heroPosition?: string;
  heroCaption?: string;
  heroParallax?: boolean;
  /** fraction of the photo's own height, at each end, left untouched by the parallax travel (default: 0.38 / 0.10) */
  heroParallaxInsets?: { top?: number; bottom?: number };
  disqusIdentifier: string;
  nextPost?: { href: string; label: string };
  videos?: VideoSchema[];
}

const {
  locale,
  title,
  description,
  altPath,
  category,
  heroImage,
  ogImage,
  heroAlt,
  heroPosition = 'center 20%',
  heroCaption,
  heroParallax = false,
  heroParallaxInsets,
  disqusIdentifier,
  nextPost,
  videos,
} = Astro.props;

// min-height + object-fit cubren el caso de imágenes muy panorámicas que en
// viewports angostos quedarían más cortas que el contenedor (sin recorrido de
// parallax, el cover evita el hueco); en imágenes 3:2 nunca entra en juego.
const heroImgStyle = heroParallax
  ? `position:absolute;top:0;left:0;width:100%;height:auto;min-height:100%;object-fit:cover;object-position:${heroPosition};display:block;transform:translate3d(0,var(--parallax-y, 0px),0);will-change:transform;`
  : `width:100%;height:100%;object-fit:cover;object-position:${heroPosition};display:block;`;

const i = t(locale);
const resourcesPath = sitePath(locale, 'resources');
const resourcesLabel = locale === 'es' ? '← Recursos' : '← Resources';
const ctaTitle = locale === 'es' ? '¿Listo para empezar?' : 'Ready to start?';
const ctaButton = locale === 'es' ? 'Agenda tu primera cita' : 'Book Your First Session';

const aboutPath = `/${locale}/${locale === 'es' ? 'sobre-mi' : 'about-me'}/`;
const bylinePrefix = locale === 'es' ? 'Por' : 'By';
const bylineCred = locale === 'es' ? 'Somatic Experiencing Practitioner (SE)' : 'Somatic Experiencing Practitioner (SE)';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "image": `https://inessentia.mx${heroImage}`,
  "inLanguage": locale,
  // author referencia el nodo Person completo (con credenciales) por @id
  "author": personRef,
  "publisher": {
    "@type": "Organization",
    "name": "Inessentia",
    "logo": { "@type": "ImageObject", "url": "https://inessentia.mx/uploads/logo-patricio-ruiz.webp" }
  },
  "mainEntityOfPage": `https://inessentia.mx${Astro.url.pathname}`
};

// nodo Person completo, para que Google resuelva las credenciales del autor
// directamente en el artículo (E-E-A-T)
const authorSchema = personSchema(locale);
---

<Base title={`${title} | Blog Inessentia`} description={description} altPath={altPath} ogImage={ogImage} schema={schema} nav="solid" extraSchemas={[
  authorSchema,
  ...(videos?.map(v => ({
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": v.name,
    "description": v.description,
    "thumbnailUrl": v.thumbnailUrl,
    "uploadDate": v.uploadDate ?? "2024-01-01T00:00:00-06:00",
    "contentUrl": v.contentUrl,
    "embedUrl": v.embedUrl,
  })) ?? []),
]}>


  <!-- HERO (fotográfico full-bleed, fusiona imagen + overlay + texto) -->
  <div style="position:relative;width:100%;height:clamp(420px,58vw,680px);overflow:hidden;">
    <Img src={heroImage} sizes="100vw" minWidth={960} alt={heroAlt} data-parallax={heroParallax || undefined} data-top-inset={heroParallax ? heroParallaxInsets?.top : undefined} data-bottom-inset={heroParallax ? heroParallaxInsets?.bottom : undefined} style={heroImgStyle} />

    <!-- degradado de abajo hacia arriba, para legibilidad del texto superpuesto -->
    <div style="position:absolute;inset:0;background:linear-gradient(0deg, rgba(38,20,60,.92) 0%, transparent 82%);pointer-events:none;"></div>

    <!-- back-link, sobre la imagen, arriba -->
    <div style="position:absolute;top:clamp(84px,11vw,116px);left:0;right:0;padding:0 32px;z-index:2;">
      <a href={resourcesPath} style="display:inline-flex;align-items:center;gap:6px;color:#fff;font-weight:700;font-size:13px;text-decoration:none;letter-spacing:.06em;text-transform:uppercase;text-shadow:0 1px 3px rgba(0,0,0,.4);">{resourcesLabel}</a>
    </div>

    <!-- categoría + h1 + descripción, en la franja inferior sobre el degradado -->
    <div style="position:absolute;left:0;right:0;bottom:0;padding:0 32px clamp(28px,4vw,48px);z-index:2;">
      <div style="max-width:760px;margin:0 auto;">
        <p style="margin:0 0 14px;font-weight:700;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#fff;">{category}</p>
        <h1 style="font-family:'Bitter',serif;font-weight:700;color:#fff;font-size:clamp(30px,4.5vw,52px);line-height:1.06;margin:0 0 16px;text-wrap:balance;">{title}</h1>
        <p style="font-size:clamp(15px,1.2vw,18px);line-height:1.6;color:rgba(255,255,255,.92);margin:0;max-width:54ch;">{description}</p>
      </div>
    </div>
  </div>
  {heroCaption && (
    <p style="max-width:680px;margin:8px auto 0;padding:0 32px;font-size:13px;color:var(--sand-d);text-align:center;">{heroCaption}</p>
  )}

  <!-- BYLINE (debajo del hero, fondo claro, para mantener legibilidad) -->
  <div style="padding:clamp(20px,3vw,28px) 32px 0;">
    <p style="max-width:760px;margin:0 auto;font-size:14px;color:var(--sand-d);">
      {bylinePrefix}{' '}
      <a href={aboutPath} rel="author" style="color:var(--wine);font-weight:700;text-decoration:none;">{PERSON_ALT_NAME}</a>
      <span style="color:var(--sand-d);"> · {bylineCred}</span>
    </p>
  </div>

  <script>
    import { initHeroParallax } from '../scripts/hero-parallax.js';
    initHeroParallax();
  </script>

  <!-- CONTENT -->
  <section style="padding:clamp(40px,6vw,72px) 32px clamp(64px,9vw,120px);">
    <div style="max-width:680px;margin:0 auto;display:flex;flex-direction:column;gap:22px;" class="blog-content">
      <slot />

      {nextPost && (
        <div style="padding-top:16px;border-top:1px solid var(--cream);display:flex;gap:16px;flex-wrap:wrap;">
          <a href={nextPost.href} class="link-underline">{nextPost.label}</a>
        </div>
      )}
    </div>
  </section>

  <!-- COMMENTS -->
  <section style="padding:clamp(48px,6vw,80px) 32px;background:var(--cream-2);">
    <div style="max-width:760px;margin:0 auto;">
      <DisqusComments
        identifier={disqusIdentifier}
        url={`https://inessentia.mx${disqusIdentifier}`}
        language={locale}
      />
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--purple);padding:clamp(56px,8vw,96px) 32px;text-align:center;">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-family:'Bitter',serif;font-weight:700;color:#fff;font-size:clamp(26px,3.5vw,42px);line-height:1.1;margin:0 0 20px;text-wrap:balance;">{ctaTitle}</h2>
      <a href="https://wa.me/patriciomx" target="_blank" rel="noopener" class="btn-white">{ctaButton}</a>
    </div>
  </section>

</Base>
