---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
import WhatsApp from '../components/WhatsApp.astro';
import RevealOnScroll from '../components/RevealOnScroll.astro';
import ParallaxImages from '../components/ParallaxImages.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { getLocale, t } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  altPath?: string; // path in the OTHER locale (e.g. /about-me/ when current is /es/sobre-mi/)
  schema?: object;
  extraSchemas?: object[];
  hideFooter?: boolean;
  noindex?: boolean;
}

const locale = getLocale(Astro.url);
const i = t(locale);
const altLocale = locale === 'es' ? 'en' : 'es';

const {
  title = i.site.title,
  description = i.site.description,
  canonical = Astro.url.href,
  ogImage = '/uploads/og/default.webp',
  altPath,
  schema,
  extraSchemas,
  hideFooter = false,
  noindex = false,
} = Astro.props;

const altHref = altPath
  ? `/${altLocale}${altPath}`
  : `/${altLocale}/`;
const altHrefAbsolute = `https://inessentia.mx${altHref}`;
const currentHref = `https://inessentia.mx${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  {noindex && <meta name="robots" content="noindex, nofollow">}
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="canonical" href={canonical}>
  <link rel="alternate" hreflang={locale} href={currentHref}>
  <link rel="alternate" hreflang={altLocale} href={altHrefAbsolute}>
  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={currentHref}>
  <meta property="og:image" content={`https://inessentia.mx${ogImage}`}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content="image/webp">
  <meta property="og:image:alt" content={title}>
  <meta property="og:locale" content={locale === 'es' ? 'es_MX' : 'en_US'}>
  <meta property="og:site_name" content="Inessentia">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={`https://inessentia.mx${ogImage}`}>
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
  {extraSchemas && extraSchemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600;700;800&family=Zilla+Slab:wght@400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600;700;800&family=Zilla+Slab:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>
  <!-- GA loads conditionally via CookieConsent component -->
</head>
<body>
  <Navbar locale={locale} altHref={altHref} />
  <MobileMenu locale={locale} />
  <main>
    <slot />
  </main>
  {!hideFooter && <Footer locale={locale} />}
  <WhatsApp locale={locale} />
  <CookieConsent locale={locale} />
  <RevealOnScroll />
  <ParallaxImages />
  <script>
    import '../scripts/video-embed.js';
  </script>
</body>
</html>
