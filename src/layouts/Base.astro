---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import MobileMenu from '../components/MobileMenu.astro';
import MenuOverlay from '../components/MenuOverlay.astro';
import Footer from '../components/Footer.astro';
import RevealOnScroll from '../components/RevealOnScroll.astro';
import ParallaxImages from '../components/ParallaxImages.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { getLocale, t } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  altPath?: string; // path in the OTHER locale (e.g. /about-me/ when current is /es/sobre-mi/)
  schema?: object;
  extraSchemas?: object[];
  hideFooter?: boolean;
  noindex?: boolean;
  // Navbar background variant: 'gradient' (default, dark hero continuation),
  // 'light' (transparent → solid --warm on scroll, purple links, for pages
  // with a light --warm hero), 'solid' (solid --cream-2 with hairline, for
  // pages without a hero below the nav), 'photo' (transparent over a
  // full-bleed photo hero, white links/wordmark, gains the brand gradient
  // on scroll — used by Home/Sobre mí per Familia A of the design handoff),
  // 'dark' (solid --purple always, for pages that continue into their own
  // solid-dark UI below, e.g. Red Inessentia's map app).
  nav?: 'gradient' | 'light' | 'solid' | 'photo' | 'dark';
  hideNav?: boolean;
  noAltLocale?: boolean;
}

const locale = getLocale(Astro.url);
const i = t(locale);
const altLocale = locale === 'es' ? 'en' : 'es';

const {
  title = i.site.title,
  description = i.site.description,
  canonical = Astro.url.href,
  ogImage = '/uploads/og/default.webp',
  altPath,
  schema,
  extraSchemas,
  hideFooter = false,
  noindex = false,
  nav = 'gradient',
  hideNav = false,
  noAltLocale = false,
} = Astro.props;

const altHref = altPath
  ? `/${altLocale}${altPath}`
  : `/${altLocale}/`;
const altHrefAbsolute = `https://inessentia.mx${altHref}`;
const currentHref = `https://inessentia.mx${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  {noindex && <meta name="robots" content="noindex, nofollow">}
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="canonical" href={canonical}>
  {!noAltLocale && <link rel="alternate" hreflang={locale} href={currentHref}>}
  {!noAltLocale && <link rel="alternate" hreflang={altLocale} href={altHrefAbsolute}>}
  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={currentHref}>
  <meta property="og:image" content={`https://inessentia.mx${ogImage}`}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content="image/webp">
  <meta property="og:image:alt" content={title}>
  <meta property="og:locale" content={locale === 'es' ? 'es_MX' : 'en_US'}>
  <meta property="og:site_name" content="Inessentia">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={`https://inessentia.mx${ogImage}`}>
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
  {extraSchemas && extraSchemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
  <!-- Fuentes auto-hospedadas (ver @font-face en global.css). Precarga de las
       críticas para el primer render; el resto se resuelve por @font-face. -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/mulish-400.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/mulish-700.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/bitter-700.woff2" crossorigin>
  <!-- GA loads conditionally via CookieConsent component -->
</head>
<body>
  {!hideNav && <Navbar locale={locale} variant={nav} />}
  {!hideNav && <MobileMenu locale={locale} />}
  {!hideNav && <MenuOverlay locale={locale} />}
  <main>
    <slot />
  </main>
  {!hideFooter && <Footer locale={locale} />}
  <CookieConsent locale={locale} />
  <RevealOnScroll />
  <ParallaxImages />
  <script>
    import '../scripts/video-embed.js';
  </script>
</body>
</html>
